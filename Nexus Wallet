async function buildSend(){
  const srcId=document.getElementById('src-sel').value;
  const amtTokens=parseFloat(document.getElementById('send-amt').value);
  const amt=toUnits(amtTokens); // convert human-readable to integer units
  const memo=document.getElementById('send-memo').value.trim();
  if(!srcId){toast('Select source','warn');return;}
  if(!_sendRecipient){toast('Enter recipient NX4ADDR','warn');return;}
  if(!amtTokens||amtTokens<=0){toast('Invalid amount','warn');return;}
  const src=OUTPUTS.get(srcId);if(!src){toast('Source not found','err');return;}
  if(CONSUMED.has(srcId)){toast('Source already consumed!','err');return;}
  if(amt>src.amount){toast('Exceeds source amount','err');return;}
  try{
    const tx=await buildSpendTx({srcOutput:src, toSid:_sendRecipient.sid, toPub:_sendRecipient.pub, amount:amt, memo});
    await acceptTx(tx);
    autoTransport(tx);   // ← auto-broadcast + outbox write
    document.getElementById('spend-str').textContent='NX4:'+btoa(JSON.stringify(tx));
    document.getElementById('spend-out').classList.add('show');
    toast('Sent · auto-broadcast','ok');
