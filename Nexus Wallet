<script>
'use strict';
// ═══════════════════════════════════════════════════════════════════
// NEXUS WALLET v4
// Fixes over v3:
//   1. Ownership binding: recipient's actual pubkey in all output creates
//   2. AWARD: uses lock.counterparty_pubkey, not resolver's pubkey
//   3. Challenge window: real — resolve rejected before expiry
//   4. Genesis: genesis_authority_pub signature verified at claim time
//   5. Authorization: from_pubkey.x === source.owner_pubkey.x enforced
//   6. Conservation: Σ inputs === Σ outputs enforced on SPEND, LOCK, RESOLVE
//   7. source_outputs included in transitions for external verification
// ═══════════════════════════════════════════════════════════════════

const BLOCK_ID  = 'w4-'+Math.random().toString(36).slice(2,8);
// FIX 4: BroadcastChannel('nexus-kernel') REMOVED — was a public channel where
// every block could read every message. Replaced with MessagePort (private pipe).
// BC_V4 remains as standalone fallback for wallet-to-wallet when kernel isn't present.
const BC_V4     = new BroadcastChannel('nexus-v4-transitions');

// ── Kernel MessagePort (FIX 4) ──
// Private point-to-point channel with the kernel. Received via BOOT message
// when running inside Nexus OS as an iframe block. Null when standalone.
let _kernelPort = null;

// ── Kernel death watchdog (FIX 1) ──
// Track last PING from kernel. If no PING in 12s, assume kernel is dead
// and fall back to BroadcastChannel. Kernel PINGs every 3s, kills after 9s.
let _lastPing = 0;
let _watchdogInterval = null;
const WATCHDOG_TIMEOUT_MS = 12000; // 12 seconds — 4 missed PINGs

// ── Transport: outbox + auto-delivery ──
// OUTBOX: localStorage key for cross-tab/late-join delivery.
// Transitions written here are read by any tab that opens later.
// Entries expire after 24 hours and are pruned on every write.
const OUTBOX_KEY = 'nx4_v4_outbox';
const OUTBOX_TTL = 24 * 3600 * 1000; // 24 hours

// ── INTEGER ARITHMETIC ──
// 1 token = 100,000,000 smallest units (like Bitcoin satoshis).
// All protocol-layer amounts are integers. Display layer divides for humans.
// This eliminates the IEEE 754 floating-point imprecision that caused the
// conservation check to use an epsilon tolerance (1e-9). With integers,
// conservation is exact: inTotal === outTotal, no tolerance.
const UNITS_PER_TOKEN = 100000000;
function toUnits(tokens) { return Math.round(tokens * UNITS_PER_TOKEN); }
function toTokens(units) { return units / UNITS_PER_TOKEN; }

// ── Wallet slot: per-tab identity isolation ──
// sessionStorage is per-tab (not shared between tabs at the same origin).
// This lets two tabs share localStorage (outbox) and BroadcastChannel
// while holding distinct keypairs and distinct SIDs.
// Opening Alice in Tab 1 and Bob in Tab 2 of the same browser profile
// gives each tab its own slot and therefore its own keypair.
const WALLET_SLOT = (() => {
  let s = sessionStorage.getItem('nx4_wallet_slot');
  if (!s) {
    s = Math.random().toString(36).slice(2, 10);
    sessionStorage.setItem('nx4_wallet_slot', s);
  }
  return s;
})();
const KP_KEY = 'nx4_kp_' + WALLET_SLOT; // per-tab keypair storage key

function writeOutbox(tx) {
  // Write a transition to the shared outbox so late-opening
  // recipient tabs can pick it up. Prunes expired entries first.
  try {
    const now = Date.now();
    const raw = localStorage.getItem(OUTBOX_KEY);
    let box = raw ? JSON.parse(raw) : [];
    // Prune expired + keep last 50
    box = box.filter(e => (now - e.ts) < OUTBOX_TTL);
    box = box.slice(-49);
    box.push({tx, ts: now});
    localStorage.setItem(OUTBOX_KEY, JSON.stringify(box));
  } catch(e) { /* storage full or unavailable — not fatal */ }
}

function txIsForMe(tx) {
  // Returns true if this transition creates any output addressed to SID,
  // or creates a lock where we are owner or counterparty.
  if (!SID) return false;
  const creates = (tx.creates || []).concat(tx.creates_change || []);
  if (creates.some(o => o.owner_sid === SID)) return true;
  if (tx.lock?.owner_sid === SID) return true;
  if (tx.lock?.counterparty_sid === SID) return true;
  return false;
}

function txAlreadyConsumed(tx) {
  // True if every consumed source/lock is already in our CONSUMED set —
  // meaning we've already accepted or originated this transition.
  const ids = (tx.consumes || []).concat(tx.consumes_lock || []);
  return ids.length > 0 && ids.every(id => CONSUMED.has(id));
}

function scanInbox() {
  // Called on boot and on storage events. Reads the shared outbox
  // and queues any transitions addressed to this wallet that we
  // haven't already consumed.
  if (!SID) return;
  try {
    const raw = localStorage.getItem(OUTBOX_KEY);
    if (!raw) return;
    const box = JSON.parse(raw);
    for (const {tx} of box) {
      if (!txIsForMe(tx)) continue;
      if (txAlreadyConsumed(tx)) continue;
      // Avoid duplicate PENDING entries
      const alreadyQueued = PENDING.some(p => {
        const pids = (p.consumes||[]).concat(p.consumes_lock||[]).join(',');
        const tids = (tx.consumes||[]).concat(tx.consumes_lock||[]).join(',');
        return pids === tids;
      });
      if (!alreadyQueued) {
        PENDING.push(tx);
        log('Inbox: transition from ' + tx.from_sid + ' (' + tx.type + ')', 'info');
      }
    }
    if (PENDING.length) { renderPending(); showIncomingBadge(); }
  } catch(e) { /* malformed outbox — ignore */ }
}

function autoTransport(tx) {
  // Called automatically after every outbound transition is locally accepted.
  // 1. MessagePort to kernel — private, authenticated, rate-limited (FIX 4)
  // 2. BroadcastChannel — fallback for standalone / kernel-dead mode
  // 3. Outbox — persistent delivery for tabs that open later (ALWAYS fires)
  if (mounted && _kernelPort) {
    _kernelPort.postMessage({
      type: 'EMIT',
      channel: 'nexus.v4.transition',
      payload: {type: 'TRANSITION', tx}
    });
    log('Auto-transport: kernel MessagePort nexus.v4.transition', 'info');
  } else {
    BC_V4.postMessage({type: 'TRANSITION', tx});
    log('Auto-transport: BC_V4 (kernel not mounted)', 'warn');
  }
  writeOutbox(tx);
}

// Storage event — another tab wrote to the outbox
window.addEventListener('storage', e => {
  if (e.key === OUTBOX_KEY && SID) {
    // Small delay so our own CONSUMED state is current before scanning
    setTimeout(scanInbox, 50);
  }
});

let KP = null, SID = null, TOKEN_SYM = 'ATT';
let OUTPUTS  = new Map();   // output_id → SpendableOutput
let LOCKS    = new Map();   // lock_id   → LockOutput
let CONSUMED = new Set();   // all consumed output/lock IDs
let JOURNAL  = [];
let PENDING  = [];
let mounted  = false;
// The genesis authority pubkey recorded on first successful genesis claim.
// All subsequent genesis claims from a different authority are rejected.
let GENESIS_AUTHORITY_PUB = null;
const GENESIS_OUTPUT = null; // injected by issuer

// ── CRYPTO ──
const b64u = b => btoa(String.fromCharCode(...new Uint8Array(b))).replace(/\+/g,'-').replace(/\//g,'_').replace(/=+$/,'');
const b64uDec = s => Uint8Array.from(atob(s.replace(/-/g,'+').replace(/_/g,'/')), c=>c.charCodeAt(0));
const enc = s => new TextEncoder().encode(s);

// ── CANONICAL SERIALIZATION ──
// Deterministic JSON with key ordering at ALL depths.
// JSON.stringify's array replacer only sorts top-level keys — nested objects
// retain JavaScript insertion order. Two wallets constructing the same logical
// object with different key insertion orders produce different byte sequences.
// This function sorts keys recursively, producing identical output regardless
// of insertion order at any nesting depth.
// Drops undefined values: JSON.stringify(undefined) returns the JS value
// undefined (not a string), which is not valid JSON. Without the filter,
// {a:1, b:undefined} produces '{"a":1,"b":undefined}' — a wallet that never
// had key "b" produces '{"a":1}'. Different bytes. Signature fails.
// REQUIRED for cross-wallet signature verification.
function canonicalize(obj) {
  if (obj === null || typeof obj !== 'object') return JSON.stringify(obj);
  if (Array.isArray(obj)) return '[' + obj.map(canonicalize).join(',') + ']';
  const keys = Object.keys(obj).sort().filter(k => obj[k] !== undefined);
  return '{' + keys.map(k => JSON.stringify(k) + ':' + canonicalize(obj[k])).join(',') + '}';
}

async function sha256(s){
  const b = await crypto.subtle.digest('SHA-256', enc(typeof s==='string'?s:JSON.stringify(s)));
  return Array.from(new Uint8Array(b)).map(x=>x.toString(16).padStart(2,'0')).join('');
}
// sign() and verify() use canonicalize() for object serialization.
// This ensures cross-wallet signature verification works regardless of
// key insertion order in the sigBody object. All signing and verification
// paths go through these two functions — fixing them fixes everything.
async function sign(key, data){
  return b64u(await crypto.subtle.sign({name:'ECDSA',hash:'SHA-256'}, key, enc(typeof data==='string'?data:canonicalize(data))));
}
async function verify(pub, data, sig){
  try{
    const k = await crypto.subtle.importKey('jwk',{kty:pub.kty,crv:pub.crv,x:pub.x,y:pub.y},{name:'ECDSA',namedCurve:'P-256'},false,['verify']);
    return await crypto.subtle.verify({name:'ECDSA',hash:'SHA-256'}, k, b64uDec(sig), enc(typeof data==='string'?data:canonicalize(data)));
  }catch{ return false; }
}
function rSalt(){ return b64u(crypto.getRandomValues(new Uint8Array(12))); }

// ── OUTPUT ID ──
// id = sha256("NX4_OUT:" + source_id + ":" + owner_pubkey.x + ":" + amount + ":" + symbol + ":" + salt + ":" + type)
// The owner's pubkey.x is embedded in the ID. Changing the pubkey changes the ID.
async function outputId(source_id, pubx, amount, symbol, salt, type){
  return sha256(`NX4_OUT:${source_id}:${pubx}:${amount}:${symbol}:${salt}:${type}`);
}

// ── LOCK ID ──
// lock_id = sha256("NX4_LOCK:" + source_id + ":" + owner_pubkey.x + ":" + cp_pubkey.x + ":" + amount + ":" + symbol + ":" + terms_hash + ":" + expiry)
// Both owner and counterparty pubkeys are embedded in the lock ID.
async function lockId(source_id, owner_pubx, cp_pubx, amount, symbol, terms_hash, expiry){
  return sha256(`NX4_LOCK:${source_id}:${owner_pubx}:${cp_pubx}:${amount}:${symbol}:${terms_hash}:${expiry}`);
}

// ── OUTPUT CREATION ──
async function mkOutput({source_id, ownerSid, ownerPub, amount, symbol, type, sigKey}){
  const salt = rSalt();
  // owner_pubkey.x is bound into the ID — wrong pubkey = wrong ID = rejected by verifier
  const id   = await outputId(source_id, ownerPub.x, amount, symbol, salt, type);
  const body = {id, source_id, owner_sid:ownerSid, owner_pubkey:ownerPub, amount, symbol, salt, type};
  const sig  = sigKey ? await sign(sigKey, body) : null;
  return {...body, sig};
}

// ── LOCK CREATION ──
async function mkLock({source_id, ownerSid, ownerPub, cpSid, cpPub, amount, symbol, termsRaw, windowHours, sigKey}){
  const terms_hash = await sha256(termsRaw);
  const expiry     = Date.now() + windowHours * 3600 * 1000;
  const id = await lockId(source_id, ownerPub.x, cpPub.x, amount, symbol, terms_hash, expiry);
  const body = {id, source_id, owner_sid:ownerSid, owner_pubkey:ownerPub,
    counterparty_sid:cpSid, counterparty_pubkey:cpPub,   // cpPub stored in lock
    amount, symbol, terms_hash, terms_raw:termsRaw, expiry, type:'LOCKED'};
  const sig = sigKey ? await sign(sigKey, body) : null;
  return {...body, sig};
}

// ── ADDRESS FORMAT ──
// NX4ADDR:SID:pubkey_x:pubkey_y
function formatAddr(sid, pub){ return `NX4ADDR:${sid}:${pub.x}:${pub.y}`; }
function parseAddr(s){
  if(!s||!s.startsWith('NX4ADDR:')) return null;
  const parts = s.split(':');
  if(parts.length<4) return null;
  const [,sid,x,y] = parts;
  if(!sid||!x||!y) return null;
  return {sid, pub:{kty:'EC',crv:'P-256',x,y}};
}

// ── GETTERS ──
function unspent(){ return [...OUTPUTS.values()].filter(o=>!CONSUMED.has(o.id)); }
function lockedOuts(){ return [...LOCKS.values()].filter(l=>!CONSUMED.has(l.id)); }
function balance(){ return unspent().reduce((s,o)=>s+o.amount,0); }
function lockedBalance(){ return lockedOuts().reduce((s,l)=>s+l.amount,0); }

// ══════════════════════════════════════════════════════
// EXISTENCE PROOF — ancestry chain from trust anchor to output
// ══════════════════════════════════════════════════════
async function verifyOutputExistence(output, depth=0, localOutputs=OUTPUTS){
  if(depth>20) return {ok:false,reason:'Proof chain depth > 20'};
  if(localOutputs&&localOutputs.has(output.id)) return {ok:true};
  const proof=output._proof;
  if(!proof) return {ok:false,reason:`No _proof on ${output.id?.slice(0,12)}...`};

  if(proof.type==='GENESIS'){
    const gOut=proof.genesis_output;
    if(!gOut?.genesis_authority_pub||!gOut.sig) return {ok:false,reason:'GENESIS proof missing authority or sig'};
    const expGId=await outputId(gOut.source_id,gOut.owner_pubkey.x,gOut.amount,gOut.symbol,gOut.salt,gOut.type);
    if(expGId!==gOut.id) return {ok:false,reason:'Genesis output ID hash invalid'};
    const gBody={id:gOut.id,source_id:gOut.source_id,owner_sid:gOut.owner_sid,owner_pubkey:gOut.owner_pubkey,amount:gOut.amount,symbol:gOut.symbol,salt:gOut.salt,type:gOut.type};
    if(!await verify(gOut.genesis_authority_pub,gBody,gOut.sig)) return {ok:false,reason:'Genesis authority signature invalid'};
    if(GENESIS_AUTHORITY_PUB&&(gOut.genesis_authority_pub.x!==GENESIS_AUTHORITY_PUB.x||gOut.genesis_authority_pub.y!==GENESIS_AUTHORITY_PUB.y)) return {ok:false,reason:'Genesis authority mismatch'};
    if(output.source_id!==gOut.id) return {ok:false,reason:`output.source_id does not match genesis_output.id`};
    const expId=await outputId(output.source_id,output.owner_pubkey.x,output.amount,output.symbol,output.salt,output.type);
    if(expId!==output.id) return {ok:false,reason:'Output ID hash invalid'};
    return {ok:true};
  }

  if(proof.type==='SPEND'){
    const parent=proof.source_output;
    if(!parent?.id) return {ok:false,reason:'SPEND proof missing source_output'};
    const pc=await verifyOutputExistence(parent,depth+1,localOutputs);
    if(!pc.ok) return {ok:false,reason:`Ancestor: ${pc.reason}`};
    if(output.source_id!==parent.id) return {ok:false,reason:`output.source_id does not match parent.id`};
    const expId=await outputId(output.source_id,output.owner_pubkey.x,output.amount,output.symbol,output.salt,output.type);
    if(expId!==output.id) return {ok:false,reason:'Output ID hash invalid'};
    // STEP 3b: Verify intermediate spend signature
    if(proof.sig && proof.from_pubkey && proof.creates_ids){
      // Authorization: signer must own the parent output (STEP 6: both x AND y)
      if(proof.from_pubkey.x!==parent.owner_pubkey.x || proof.from_pubkey.y!==parent.owner_pubkey.y)
        return {ok:false,reason:'ANCESTRY_AUTH: signer pubkey does not match parent owner'};
      // Reconstruct SPEND sigBody and verify signature
      const sigBody={consumes:[parent.id], creates_ids:proof.creates_ids, from_sid:proof.from_sid, ts:proof.ts};
      if(!await verify(proof.from_pubkey, sigBody, proof.sig))
        return {ok:false,reason:'ANCESTRY_SIG: intermediate spend signature invalid'};
      // Membership check: this output must be in the signed creates set
      if(!proof.creates_ids.includes(output.id))
        return {ok:false,reason:'ANCESTRY_MEMBERSHIP: output not in signed creates set'};
    }
    // Legacy proofs without sig fields pass structural checks only (backward compat)
    return {ok:true};
  }

  if(proof.type==='LOCK_CHANGE'){
    // Change output created by a LOCK transaction — uses LOCK sigBody shape
    const parent=proof.source_output;
    if(!parent?.id) return {ok:false,reason:'LOCK_CHANGE proof missing source_output'};
    const pc=await verifyOutputExistence(parent,depth+1,localOutputs);
    if(!pc.ok) return {ok:false,reason:`Ancestor: ${pc.reason}`};
    if(output.source_id!==parent.id) return {ok:false,reason:`output.source_id does not match parent.id`};
    const expId=await outputId(output.source_id,output.owner_pubkey.x,output.amount,output.symbol,output.salt,output.type);
    if(expId!==output.id) return {ok:false,reason:'Output ID hash invalid'};
    if(proof.sig && proof.from_pubkey && proof.lock_id && proof.creates_change_ids){
      if(proof.from_pubkey.x!==parent.owner_pubkey.x || proof.from_pubkey.y!==parent.owner_pubkey.y)
        return {ok:false,reason:'ANCESTRY_AUTH: signer pubkey does not match parent owner'};
      // Reconstruct LOCK sigBody shape
      const sigBody={consumes:[parent.id], lock_id:proof.lock_id, creates_change_ids:proof.creates_change_ids, from_sid:proof.from_sid, ts:proof.ts};
      if(!await verify(proof.from_pubkey, sigBody, proof.sig))
        return {ok:false,reason:'ANCESTRY_SIG: intermediate lock signature invalid'};
      // Membership: change output must be in signed creates_change set
      if(!proof.creates_change_ids.includes(output.id))
        return {ok:false,reason:'ANCESTRY_MEMBERSHIP: output not in signed lock creates_change set'};
    }
    return {ok:true};
  }

  if(proof.type==='RESOLVE'){
    const lock=proof.lock_output||proof.lock;  // lock_output (new) or lock (legacy)
    if(!lock?.id) return {ok:false,reason:'RESOLVE proof missing lock'};
    if(output.source_id!==lock.id) return {ok:false,reason:'output.source_id does not match lock.id'};
    const expId=await outputId(output.source_id,output.owner_pubkey.x,output.amount,output.symbol,output.salt,output.type);
    if(expId!==output.id) return {ok:false,reason:'Output ID hash invalid'};
    const expLockId=await lockId(lock.source_id,lock.owner_pubkey.x,lock.counterparty_pubkey.x,lock.amount,lock.symbol,lock.terms_hash,lock.expiry);
    if(expLockId!==lock.id) return {ok:false,reason:'Lock ID hash invalid in RESOLVE proof'};
    // STEP 3b: Verify resolve signature (sigBody includes type:'RESOLVE' — asymmetric)
    if(proof.sig && proof.from_pubkey && proof.creates_ids){
      // Authorization: resolver must be lock owner (STEP 6: both x AND y)
      if(proof.from_pubkey.x!==lock.owner_pubkey.x || proof.from_pubkey.y!==lock.owner_pubkey.y)
        return {ok:false,reason:'ANCESTRY_AUTH: resolver pubkey does not match lock owner'};
      const sigBody={type:'RESOLVE', consumes_lock:[lock.id], resolution:proof.resolution, creates_ids:proof.creates_ids, from_sid:proof.from_sid, ts:proof.ts};
      if(!await verify(proof.from_pubkey, sigBody, proof.sig))
        return {ok:false,reason:'ANCESTRY_SIG: resolve signature invalid'};
      if(!proof.creates_ids.includes(output.id))
        return {ok:false,reason:'ANCESTRY_MEMBERSHIP: output not in signed resolve creates set'};
    }
    // FIX 3: Recurse through the lock's own ancestry.
    if(lock._source_proof){
      const lockSource = {
        id: lock.source_id,
        owner_pubkey: lock.owner_pubkey,
        amount: lock.amount,
        symbol: lock.symbol,
        salt: lock._source_salt || '',
        type: lock._source_type || 'spendable',
        _proof: lock._source_proof
      };
      const lockAncestry = await verifyOutputExistence(lockSource, depth+1, localOutputs);
      if(!lockAncestry.ok) return {ok:false,reason:'Lock ancestry failed: '+lockAncestry.reason};
    } else if(!localOutputs || !localOutputs.has(lock.source_id)){
      return {ok:false,reason:'Lock source '+lock.source_id.slice(0,12)+'... not in local state and no _source_proof carried'};
    }
    return {ok:true};
  }

  return {ok:false,reason:`Unknown proof type: ${proof.type}`};
}

// ══════════════════════════════════════════════════════
// TRANSITION BUILDERS
// ══════════════════════════════════════════════════════

// ── SPEND ──
async function buildSpendTx({srcOutput, toSid, toPub, amount, memo}){
  if(CONSUMED.has(srcOutput.id)) throw new Error('Source already consumed');
  if(amount>srcOutput.amount) throw new Error('Amount exceeds source');
  if(srcOutput.owner_pubkey.x !== KP._pub.x || srcOutput.owner_pubkey.y !== KP._pub.y) throw new Error('Authorization: this wallet does not own the source output');
  const change = srcOutput.amount - amount; // integer subtraction — exact
  // toPub is required — the recipient's actual pubkey binds the output to them
  if(!toPub) throw new Error('Recipient pubkey required — cannot create ownership-bound output without it');
  const creates = [];
  creates.push(await mkOutput({source_id:srcOutput.id, ownerSid:toSid, ownerPub:toPub, amount, symbol:srcOutput.symbol, type:'spendable', sigKey:KP.privateKey}));
  if(change>0) creates.push(await mkOutput({source_id:srcOutput.id, ownerSid:SID, ownerPub:KP._pub, amount:change, symbol:srcOutput.symbol, type:'change', sigKey:KP.privateKey}));
  const ts = Date.now();
  // Conservation pre-check (also checked by verifier) — exact integer equality
  const outTotal = creates.reduce((s,o)=>s+o.amount,0);
  if(srcOutput.amount !== outTotal) throw new Error(`Conservation: source=${srcOutput.amount} outputs=${outTotal}`);
  const creates_ids = creates.map(o=>o.id);
  const sigBody = {consumes:[srcOutput.id], creates_ids, from_sid:SID, ts};
  const sig = await sign(KP.privateKey, sigBody);
  // STEP 3d: Backfill full proof-hop data AFTER signing.
  // The signature didn't exist when outputs were created (Trap 1).
  // Each output carries the full proof chain so any future receiver can
  // walk the ancestry and verify every intermediate signature.
  for(const out of creates){
    out._proof = {
      type: 'SPEND',
      source_output: srcOutput,   // carries srcOutput._proof (full chain)
      sig,
      from_pubkey: KP._pub,
      from_sid: SID,
      ts,
      creates_ids
    };
  }
  return {type:'SPEND', v:4, consumes:[srcOutput.id], source_outputs:[srcOutput], creates, from_sid:SID, from_pubkey:KP._pub, memo:memo||'', ts, sig};
}

// ── LOCK ──
async function buildLockTx({srcOutput, amount, cpSid, cpPub, termsRaw, windowHours}){
  if(CONSUMED.has(srcOutput.id)) throw new Error('Source already consumed');
  if(amount>srcOutput.amount) throw new Error('Amount exceeds source');
  if(srcOutput.owner_pubkey.x !== KP._pub.x || srcOutput.owner_pubkey.y !== KP._pub.y) throw new Error('Authorization: this wallet does not own the source output');
  if(!cpPub) throw new Error('Counterparty pubkey required — needed to bind AWARD output');
  const change = srcOutput.amount - amount; // integer subtraction — exact
  const lock = await mkLock({source_id:srcOutput.id, ownerSid:SID, ownerPub:KP._pub, cpSid, cpPub, amount, symbol:srcOutput.symbol, termsRaw, windowHours, sigKey:KP.privateKey});
  const creates_change = [];
  if(change>0) creates_change.push(await mkOutput({source_id:srcOutput.id, ownerSid:SID, ownerPub:KP._pub, amount:change, symbol:srcOutput.symbol, type:'change', sigKey:KP.privateKey}));
  // Conservation pre-check — exact integer equality
  const lockAmt = lock.amount;
  const changeAmt = creates_change.reduce((s,o)=>s+o.amount,0);
  if(srcOutput.amount !== (lockAmt + changeAmt)) throw new Error(`Conservation: source=${srcOutput.amount} lock+change=${lockAmt+changeAmt}`);
  const ts = Date.now();
  const creates_change_ids = creates_change.map(o=>o.id);
  const sigBody = {consumes:[srcOutput.id], lock_id:lock.id, creates_change_ids, from_sid:SID, ts};
  const sig = await sign(KP.privateKey, sigBody);
  // STEP 3d: Backfill proof-hop data on change outputs (LOCK_CHANGE type).
  // The verifier needs the LOCK sigBody shape to reconstruct and verify.
  for(const out of creates_change){
    out._proof = {
      type: 'LOCK_CHANGE',
      source_output: srcOutput,
      sig,
      from_pubkey: KP._pub,
      from_sid: SID,
      ts,
      lock_id: lock.id,
      creates_change_ids
    };
  }
  // Attach source ancestry to lock for cross-wallet verification (extends FIX 3)
  if(srcOutput._proof) lock._source_proof = srcOutput._proof;
  lock._source_salt = srcOutput.salt;
  lock._source_type = srcOutput.type;
  return {type:'LOCK', v:4, consumes:[srcOutput.id], source_outputs:[srcOutput], lock, creates_change, from_sid:SID, from_pubkey:KP._pub, ts, sig};
}

// ── RESOLVE ──
async function buildResolveTx({lockOutput, resolutionType}){
  if(CONSUMED.has(lockOutput.id)) throw new Error('Lock already consumed');
  if(lockOutput.owner_pubkey.x !== KP._pub.x || lockOutput.owner_pubkey.y !== KP._pub.y) throw new Error('Authorization: only lock owner can resolve');
  const window_expired = Date.now() > lockOutput.expiry;
  if(!window_expired) throw new Error(`Challenge window has not expired. Expires: ${new Date(lockOutput.expiry).toLocaleString()}`);
  const ts = Date.now();
  const creates = [];
  if(resolutionType==='RELEASE'){
    // Return to owner: use lock.owner_pubkey
    creates.push(await mkOutput({source_id:lockOutput.id, ownerSid:lockOutput.owner_sid, ownerPub:lockOutput.owner_pubkey, amount:lockOutput.amount, symbol:lockOutput.symbol, type:'spendable', sigKey:KP.privateKey}));
  } else if(resolutionType==='AWARD'){
    // Send to counterparty: use lock.counterparty_pubkey (stored in lock, not resolver's key)
    creates.push(await mkOutput({source_id:lockOutput.id, ownerSid:lockOutput.counterparty_sid, ownerPub:lockOutput.counterparty_pubkey, amount:lockOutput.amount, symbol:lockOutput.symbol, type:'spendable', sigKey:KP.privateKey}));
  }
  // SLASH: creates nothing (funds burned — no conservation requirement)
  const creates_ids = creates.map(o=>o.id);
  const sigBody = {type:'RESOLVE', consumes_lock:[lockOutput.id], resolution:resolutionType, creates_ids, from_sid:SID, ts};
  const sig = await sign(KP.privateKey, sigBody);
  // STEP 3d: Backfill proof-hop data on resolve outputs.
  // RESOLVE sigBody includes type:'RESOLVE' — asymmetric with SPEND/LOCK.
  for(const out of creates){
    out._proof = {
      type: 'RESOLVE',
      lock_output: lockOutput,   // carries lock's own ancestry
      sig,
      from_pubkey: KP._pub,
      from_sid: SID,
      ts,
      resolution: resolutionType,
      creates_ids
    };
  }
  return {type:'RESOLVE', v:4, consumes_lock:[lockOutput.id], lock_snapshot:lockOutput, resolution:resolutionType, creates, from_sid:SID, from_pubkey:KP._pub, ts, sig};
}

// ══════════════════════════════════════════════════════
// VERIFICATION — all four rules in strict order
// ══════════════════════════════════════════════════════

async function verifySpend(tx){
  if(tx.v!==4||tx.type!=='SPEND') return {ok:false,r:'Not NX4 SPEND'};
  if(!tx.consumes?.length) return {ok:false,r:'No consumed sources declared'};

  // Rule 1: consumed-source check — before any crypto
  for(const cid of tx.consumes)
    if(CONSUMED.has(cid)) return {ok:false,r:`DOUBLE-SPEND: source ${cid.slice(0,12)}... already consumed`};

  // Rule 2: local state first, then existence proof chain for foreign sources
  const srcs = [];
  for(const cid of tx.consumes){
    const local = OUTPUTS.get(cid);
    if(local){ srcs.push(local); }
    else {
      const carried=(tx.source_outputs||[]).find(s=>s.id===cid);
      if(!carried) return {ok:false,r:`Source ${cid.slice(0,12)}... not in local state — carry source_outputs with _proof`};
      const ec=await verifyOutputExistence(carried,0,OUTPUTS);
      if(!ec.ok) return {ok:false,r:`Existence proof failed for ${cid.slice(0,12)}...: ${ec.reason}`};
      srcs.push(carried);
    }
  }

  // Authorization: signer must own every consumed source (STEP 6: x AND y)
  for(const src of srcs){
    if(src.owner_pubkey.x !== tx.from_pubkey.x || src.owner_pubkey.y !== tx.from_pubkey.y)
      return {ok:false,r:`AUTHORIZATION FAILURE: signer does not own source ${src.id.slice(0,12)}... owner=${src.owner_pubkey.x.slice(0,16)}... signer=${tx.from_pubkey.x.slice(0,16)}...`};
  }

  // Rule 3: signature
  const sigBody = {consumes:tx.consumes, creates_ids:tx.creates.map(o=>o.id), from_sid:tx.from_sid, ts:tx.ts};
  if(!await verify(tx.from_pubkey, sigBody, tx.sig)) return {ok:false,r:'Invalid sender signature'};

  // Rule 4: conservation — exact integer equality, no epsilon
  const inTotal  = srcs.reduce((s,o)=>s+o.amount, 0);
  const outTotal = tx.creates.reduce((s,o)=>s+o.amount, 0);
  if(!Number.isSafeInteger(inTotal)||!Number.isSafeInteger(outTotal))
    return {ok:false,r:'Amount exceeds safe integer range'};
  if(inTotal !== outTotal)
    return {ok:false,r:`CONSERVATION VIOLATION: inputs=${inTotal} outputs=${outTotal} (Δ=${inTotal-outTotal})`};

  for(const out of tx.creates){
    const exp = await outputId(out.source_id, out.owner_pubkey.x, out.amount, out.symbol, out.salt, out.type);
    if(exp !== out.id) return {ok:false,r:`Output ID mismatch: ${out.id.slice(0,12)}...`};
    if(!tx.consumes.includes(out.source_id)) return {ok:false,r:'Output source_id not in consumes list'};
  }
  return {ok:true};
}

async function verifyLock(tx){
  if(tx.v!==4||tx.type!=='LOCK') return {ok:false,r:'Not NX4 LOCK'};
  if(!tx.consumes?.length) return {ok:false,r:'No consumed sources declared'};
  const lock = tx.lock;
  if(!lock) return {ok:false,r:'Missing lock object'};

  // Rule 1: consumed-source check
  for(const cid of tx.consumes)
    if(CONSUMED.has(cid)) return {ok:false,r:`DOUBLE-SPEND: source ${cid.slice(0,12)}... already consumed`};

  // Rule 2: local state first, then existence proof chain for foreign sources
  const srcs = [];
  for(const cid of tx.consumes){
    const local = OUTPUTS.get(cid);
    if(local){ srcs.push(local); }
    else {
      const carried=(tx.source_outputs||[]).find(s=>s.id===cid);
      if(!carried) return {ok:false,r:`Source ${cid.slice(0,12)}... not in local state — carry source_outputs with _proof`};
      const ec=await verifyOutputExistence(carried,0,OUTPUTS);
      if(!ec.ok) return {ok:false,r:`Existence proof failed for ${cid.slice(0,12)}...: ${ec.reason}`};
      srcs.push(carried);
    }
  }

  // Authorization (STEP 6: x AND y)
  for(const src of srcs){
    if(src.owner_pubkey.x !== tx.from_pubkey.x || src.owner_pubkey.y !== tx.from_pubkey.y)
      return {ok:false,r:`AUTHORIZATION FAILURE: signer does not own source ${src.id.slice(0,12)}...`};
  }

  // Rule 3: signature
  const sigBody = {consumes:tx.consumes, lock_id:lock.id, creates_change_ids:tx.creates_change.map(o=>o.id), from_sid:tx.from_sid, ts:tx.ts};
  if(!await verify(tx.from_pubkey, sigBody, tx.sig)) return {ok:false,r:'Invalid lock signature'};

  // Lock ID verification
  const expLockId = await lockId(lock.source_id, lock.owner_pubkey.x, lock.counterparty_pubkey.x, lock.amount, lock.symbol, lock.terms_hash, lock.expiry);
  if(expLockId !== lock.id) return {ok:false,r:'Lock ID does not verify (owner or counterparty pubkey mismatch)'};

  // Rule 4: conservation — exact integer equality, no epsilon
  const inTotal  = srcs.reduce((s,o)=>s+o.amount,0);
  const outTotal = lock.amount + tx.creates_change.reduce((s,o)=>s+o.amount,0);
  if(!Number.isSafeInteger(inTotal)||!Number.isSafeInteger(outTotal))
    return {ok:false,r:'Amount exceeds safe integer range'};
  if(inTotal !== outTotal)
    return {ok:false,r:`CONSERVATION VIOLATION: source=${inTotal} lock+change=${outTotal}`};

  return {ok:true};
}

async function verifyResolve(tx){
  if(tx.v!==4||tx.type!=='RESOLVE') return {ok:false,r:'Not NX4 RESOLVE'};
  if(!tx.consumes_lock?.length) return {ok:false,r:'No lock ID declared'};

  // Rule 1: consumed-lock check
  for(const lid of tx.consumes_lock)
    if(CONSUMED.has(lid)) return {ok:false,r:`DOUBLE-RESOLVE: lock ${lid.slice(0,12)}... already consumed`};

  // Rule D: resolve lock against local authoritative LOCKS map.
  // A pasted resolve for a lock this wallet never accepted is rejected.
  // tx.lock_snapshot is only used as a fallback label; the authoritative
  // data always comes from LOCKS.get().
  const lid = tx.consumes_lock[0];
  const lock = LOCKS.get(lid);
  if(!lock)
    return {ok:false,r:`Lock ${lid.slice(0,12)}... not in local accepted state — cannot verify resolve (paste the LOCK transition first)`};

  // Rule 2: authorization — resolver must be lock owner (STEP 6: x AND y)
  if(lock.owner_pubkey.x !== tx.from_pubkey.x || lock.owner_pubkey.y !== tx.from_pubkey.y)
    return {ok:false,r:`AUTHORIZATION FAILURE: resolver is not the lock owner (expected ${lock.owner_pubkey.x.slice(0,16)}... got ${tx.from_pubkey.x.slice(0,16)}...)`};

  // Challenge window: derived from local lock.expiry — tx boolean is ignored
  const window_expired = Date.now() > lock.expiry;
  if(!window_expired)
    return {ok:false,r:`PREMATURE RESOLVE: challenge window has not expired (expires ${new Date(lock.expiry).toLocaleString()})`};

  // Rule 3: signature
  const sigBody = {type:'RESOLVE', consumes_lock:tx.consumes_lock, resolution:tx.resolution, creates_ids:tx.creates.map(o=>o.id), from_sid:tx.from_sid, ts:tx.ts};
  if(!await verify(tx.from_pubkey, sigBody, tx.sig)) return {ok:false,r:'Invalid resolve signature'};

  // Rule 4: conservation
  if(tx.resolution==='SLASH'){
    if(tx.creates.length!==0) return {ok:false,r:'SLASH must create 0 outputs'};
  } else {
    if(tx.creates.length!==1) return {ok:false,r:`${tx.resolution} must create exactly 1 output`};
    if(tx.creates[0].amount !== lock.amount)
      return {ok:false,r:`CONSERVATION VIOLATION: lock=${lock.amount} output=${tx.creates[0].amount}`};
    if(tx.resolution==='RELEASE' && (tx.creates[0].owner_pubkey.x !== lock.owner_pubkey.x || tx.creates[0].owner_pubkey.y !== lock.owner_pubkey.y))
      return {ok:false,r:'RELEASE output must be bound to lock owner pubkey'};
    if(tx.resolution==='AWARD' && (tx.creates[0].owner_pubkey.x !== lock.counterparty_pubkey.x || tx.creates[0].owner_pubkey.y !== lock.counterparty_pubkey.y))
      return {ok:false,r:`AWARD output must be bound to counterparty pubkey from local lock record`};
    for(const out of tx.creates){
      const exp = await outputId(out.source_id, out.owner_pubkey.x, out.amount, out.symbol, out.salt, out.type);
      if(exp!==out.id) return {ok:false,r:`Resolve output ID mismatch: ${out.id.slice(0,12)}...`};
    }
  }
  return {ok:true};
}

async function acceptTx(tx){
  let result;
  if(tx.type==='SPEND')   result = await verifySpend(tx);
  else if(tx.type==='LOCK')    result = await verifyLock(tx);
  else if(tx.type==='RESOLVE') result = await verifyResolve(tx);
  else return false;
  if(!result.ok){ log(result.r,'err'); return false; }

  const entry = {tx, ts:Date.now()};
  if(tx.type==='SPEND'){
    for(const cid of tx.consumes) CONSUMED.add(cid);
    const spendSrc=OUTPUTS.get(tx.consumes[0])||(tx.source_outputs||[]).find(s=>s.id===tx.consumes[0]);
    for(const out of tx.creates){
      if(out.owner_sid===SID){
        // STEP 3c: Store full proof-hop data so the NEXT receiver can verify
        // the entire chain. spendSrc carries its own _proof (Russian-doll nesting).
        out._proof={
          type:'SPEND',
          source_output:spendSrc,
          sig:tx.sig,
          from_pubkey:tx.from_pubkey,
          from_sid:tx.from_sid,
          ts:tx.ts,
          creates_ids:tx.creates.map(o=>o.id)
        };
        OUTPUTS.set(out.id,out);
      }
    }
    TOKEN_SYM = tx.creates[0]?.symbol||TOKEN_SYM;
    entry.label = `SPEND: consumed ${tx.consumes[0].slice(0,10)}...`;
  }
  if(tx.type==='LOCK'){
    for(const cid of tx.consumes) CONSUMED.add(cid);
    LOCKS.set(tx.lock.id, tx.lock);
    const lockSrc=OUTPUTS.get(tx.consumes[0])||(tx.source_outputs||[]).find(s=>s.id===tx.consumes[0]);
    for(const out of tx.creates_change){
      if(out.owner_sid===SID){
        // STEP 3c: LOCK_CHANGE — verifier reconstructs LOCK sigBody shape
        out._proof={
          type:'LOCK_CHANGE',
          source_output:lockSrc,
          sig:tx.sig,
          from_pubkey:tx.from_pubkey,
          from_sid:tx.from_sid,
          ts:tx.ts,
          lock_id:tx.lock.id,
          creates_change_ids:tx.creates_change.map(o=>o.id)
        };
        OUTPUTS.set(out.id,out);
      }
    }
    TOKEN_SYM = tx.lock.symbol||TOKEN_SYM;
    entry.label = `LOCK: ${tx.lock.amount} ${tx.lock.symbol} locked · expiry ${new Date(tx.lock.expiry).toLocaleString()}`;
  }
  if(tx.type==='RESOLVE'){
    // Capture authoritative lock BEFORE deletion — tx.lock_snapshot is attacker-controlled
    const resolvedLock = LOCKS.get(tx.consumes_lock[0]);
    for(const lid of tx.consumes_lock){ CONSUMED.add(lid); LOCKS.delete(lid); }
    for(const out of tx.creates){
      if(out.owner_sid===SID){
        // STEP 3c: Full RESOLVE proof with authoritative lock data.
        // RESOLVE sigBody includes type:'RESOLVE' — asymmetric with SPEND/LOCK.
        out._proof={
          type:'RESOLVE',
          lock_output:resolvedLock||tx.lock_snapshot,  // prefer local, fallback to snapshot
          sig:tx.sig,
          from_pubkey:tx.from_pubkey,
          from_sid:tx.from_sid,
          ts:tx.ts,
          resolution:tx.resolution,
          creates_ids:tx.creates.map(o=>o.id)
        };
        OUTPUTS.set(out.id,out);
      }
    }
    entry.label = `RESOLVE(${tx.resolution}): lock ${tx.consumes_lock[0].slice(0,10)}... → ${tx.creates.map(o=>`${o.amount} ${o.symbol} → ${o.owner_sid}`).join(', ')||'BURNED'}`;
  }
  JOURNAL.push(entry);
  persist();
  renderAll();
  log(entry.label, tx.type==='LOCK'?'lock':tx.type==='RESOLVE'?'resolve':'ok');
  return true;
}

// ── GENESIS ──
async function issueLocalGenesis(){
  const amtTokens = parseFloat(document.getElementById('gen-amt').value)||10000;
  const amt = toUnits(amtTokens); // convert human-readable tokens to integer units
  const sym = document.getElementById('gen-sym').value.trim().toUpperCase()||'ATT';
  const salt = rSalt();
  const id = await outputId('GENESIS_ROOT', KP._pub.x, amt, sym, salt, 'genesis');
  const body = {id, source_id:'GENESIS_ROOT', owner_sid:SID, owner_pubkey:KP._pub, amount:amt, symbol:sym, salt, type:'genesis'};
  const sig = await sign(KP.privateKey, body); // self-signed demo
  const gOut = {...body, sig, genesis_authority_pub:KP._pub}; // self is authority
  const r = await claimGenesisOutput(gOut);
  if(r.ok){ toast(`Genesis: ${amtTokens} ${sym}`,'ok'); renderAll(); }
  else toast(r.reason,'err');
}

async function claimGenesisFromPaste(){
