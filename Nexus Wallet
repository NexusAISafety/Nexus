  let obj; try{ obj=JSON.parse(txt); }catch(e){ toast('Invalid JSON','err'); return; }
  const r = await claimGenesisOutput(obj);
  if(r.ok){ toast('Genesis claimed!','ok'); renderAll(); }
  else toast(r.reason,'err');
}

async function claimGenesisOutput(gOut){
  if(!gOut?.id) return {ok:false,reason:'Missing id'};
  if(gOut.source_id!=='GENESIS_ROOT') return {ok:false,reason:'source_id must be GENESIS_ROOT'};
  if(!gOut.genesis_authority_pub) return {ok:false,reason:'Missing genesis_authority_pub — unverifiable genesis'};

  // Rule 1: consumed check
  if(CONSUMED.has(gOut.id)){
    updateGenesisBanner('err','✗ DOUBLE-CLAIM BLOCKED — genesis output already consumed. This file is a copy.');
    return {ok:false,reason:`DOUBLE-CLAIM BLOCKED: genesis output ${gOut.id.slice(0,12)}... already consumed`};
  }

  // Rule 2: genesis authority signature verification
  // The sig must have been produced by genesis_authority_pub over the output body
  const bodyForSig = {id:gOut.id, source_id:gOut.source_id, owner_sid:gOut.owner_sid, owner_pubkey:gOut.owner_pubkey, amount:gOut.amount, symbol:gOut.symbol, salt:gOut.salt, type:gOut.type};
  const sigValid = await verify(gOut.genesis_authority_pub, bodyForSig, gOut.sig);
  if(!sigValid) return {ok:false,reason:'GENESIS AUTHORITY SIGNATURE INVALID — genesis output is fraudulent'};

  // Rule 3: authority consistency — if we've seen a genesis before, it must be from the same authority (STEP 6: x AND y)
  if(GENESIS_AUTHORITY_PUB && (gOut.genesis_authority_pub.x !== GENESIS_AUTHORITY_PUB.x || gOut.genesis_authority_pub.y !== GENESIS_AUTHORITY_PUB.y))
    return {ok:false,reason:'GENESIS AUTHORITY MISMATCH — different authority from first-seen genesis'};

  // Rule 4: output ID verification
  const exp = await outputId(gOut.source_id, gOut.owner_pubkey.x, gOut.amount, gOut.symbol, gOut.salt, gOut.type);
  if(exp !== gOut.id) return {ok:false,reason:'Genesis output ID does not verify'};

  // Accept
  CONSUMED.add(gOut.id);
  if(!GENESIS_AUTHORITY_PUB) GENESIS_AUTHORITY_PUB = gOut.genesis_authority_pub;

  const spendable = await mkOutput({source_id:gOut.id, ownerSid:SID, ownerPub:KP._pub, amount:gOut.amount, symbol:gOut.symbol, type:'genesis-claim', sigKey:KP.privateKey});
  spendable._proof = {type:'GENESIS', genesis_output:gOut};
  OUTPUTS.set(spendable.id, spendable);
  TOKEN_SYM = gOut.symbol;
  JOURNAL.push({tx:{type:'GENESIS_CLAIM',v:4,genesis_id:gOut.id,spendable_id:spendable.id,amount:gOut.amount,symbol:gOut.symbol,ts:Date.now()},ts:Date.now(),label:`GENESIS_CLAIM: ${toTokens(gOut.amount)} ${gOut.symbol}`});

  updateGenesisBanner('ok',`✓ Genesis claimed — ${toTokens(gOut.amount)} ${gOut.symbol} · Authority sig: verified · Output: ${spendable.id.slice(0,14)}...`);
  showGenesisAuthority(gOut.genesis_authority_pub);
  persist();
  return {ok:true};
}

