  if(!JOURNAL.length){sl.innerHTML='<div style="color:var(--muted);font-size:10px">No transitions yet.</div>';return;}
  document.getElementById('settlement-ok').style.display='block';
  document.getElementById('settlement-ok').textContent=`${JOURNAL.length} transition${JOURNAL.length>1?'s':''} in local settlement journal.`;
  const colorOf={SPEND:'var(--green)',LOCK:'var(--indigo)',RESOLVE:'var(--cyan)',GENESIS_CLAIM:'var(--gold)'};
  sl.innerHTML=[...JOURNAL].reverse().slice(0,20).map(e=>`<div style="border-left:2px solid ${colorOf[e.tx.type]||'var(--border)'};padding-left:10px;margin-bottom:8px">
    <div style="font-size:10px;color:${colorOf[e.tx.type]||'var(--text)'}">${e.tx.type} v${e.tx.v||'—'}</div>
    <div style="font-size:9px;color:var(--dim);line-height:1.6">${new Date(e.ts).toLocaleString()}<br>${e.label||''}
    ${e.tx.type==='RESOLVE'?`<br>Resolution: <strong style="color:var(--cyan)">${e.tx.resolution}</strong> · window_expired: ${Date.now()>(e.tx.lock_snapshot?.expiry||0)} (derived from lock.expiry)`:''}
    </div></div>`).join('');

  const fl=document.getElementById('finality-list');
  const fins=lockedOuts().map(l=>{
    const exp=Date.now()>l.expiry;
    return `<div class="fin-row"><div class="fin-icon">⛓</div><div class="fin-body"><div class="fin-label">${l.id.slice(0,14)}...</div><div class="fin-detail">${fmt(l.amount)} ${l.symbol} · CP: ${l.counterparty_sid} · exp: ${new Date(l.expiry).toLocaleString()}</div></div><div class="fin-state ${exp?'final':'locked'}">${exp?'RESOLVABLE':'LOCKED'}</div></div>`;
  }).concat(JOURNAL.filter(e=>e.tx.type==='RESOLVE').slice(-5).map(e=>{
    const cls=e.tx.resolution==='SLASH'?'slashed':e.tx.resolution==='RELEASE'?'released':'final';
    return `<div class="fin-row"><div class="fin-icon">⚖</div><div class="fin-body"><div class="fin-label">RESOLVED ${e.tx.resolution}</div><div class="fin-detail">${new Date(e.ts).toLocaleString()} · lock: ${e.tx.consumes_lock[0].slice(0,12)}...</div></div><div class="fin-state ${cls}">${e.tx.resolution}</div></div>`;
  }));
  fl.innerHTML=fins.join('')||'<div style="color:var(--muted);font-size:10px">No active lock states.</div>';
}

// ── ADVERSARIAL PROOF ──
let proofRunning=false;

async function runProof(){
  if(proofRunning) return;
  proofRunning=true;
  document.getElementById('proof-btn').disabled=true;
  document.getElementById('proof-btn').textContent='⏳ Running...';
  clearProof();

  const steps=document.getElementById('proof-steps');
  let errors=0;

  async function step(type,label,detail){
    const icons={pass:'✓',fail:'✗',block:'⛔',lock:'⛓',resolve:'⚖',info:'→'};
    const d=document.createElement('div');
    d.className=`pstep ${type}`;
    d.innerHTML=`<div class="psi">${icons[type]||'·'}</div><div class="psb"><div class="psl">${label}</div><div class="psd">${detail}</div></div>`;
    steps.appendChild(d); d.scrollIntoView({behavior:'smooth',block:'nearest'});
    return new Promise(r=>setTimeout(r,80));
  }
  function w(ms){return new Promise(r=>setTimeout(r,ms));}

  // Isolated proof state
  const P={consumed:new Set(),outputs:new Map(),locks:new Map()};

  // Rule-checking functions — mirror real verifySpend/verifyLock, using P state
  async function pVerifySpend(tx){
    if(!tx.consumes?.length) return {ok:false,r:'No consumed sources'};
    for(const cid of tx.consumes) if(P.consumed.has(cid)) return {ok:false,r:`DOUBLE-SPEND: ${cid.slice(0,12)}... already consumed`};
    const srcs=[];
    for(const cid of tx.consumes){
      const local=P.outputs.get(cid);
      if(local){ srcs.push(local); }
      else {
        const carried=(tx.source_outputs||[]).find(s=>s.id===cid);
        if(!carried) return {ok:false,r:`Source ${cid.slice(0,12)}... not in proof state`};
        const ec=await verifyOutputExistence(carried,0,P.outputs);
        if(!ec.ok) return {ok:false,r:`Existence proof failed: ${ec.reason}`};
        srcs.push(carried);
      }
    }
    for(const src of srcs) if(src.owner_pubkey.x!==tx.from_pubkey.x||src.owner_pubkey.y!==tx.from_pubkey.y) return {ok:false,r:`AUTHORIZATION FAILURE: signer does not own ${src.id.slice(0,12)}...`};
    const sigBody={consumes:tx.consumes,creates_ids:tx.creates.map(o=>o.id),from_sid:tx.from_sid,ts:tx.ts};
    if(!await verify(tx.from_pubkey,sigBody,tx.sig)) return {ok:false,r:'Invalid signature'};
    const inT=srcs.reduce((s,o)=>s+o.amount,0), outT=tx.creates.reduce((s,o)=>s+o.amount,0);
    if(inT!==outT) return {ok:false,r:`CONSERVATION: in=${inT} out=${outT}`};
    for(const out of tx.creates){
      const exp=await outputId(out.source_id,out.owner_pubkey.x,out.amount,out.symbol,out.salt,out.type);
      if(exp!==out.id) return {ok:false,r:`Output ID mismatch: ${out.id.slice(0,12)}...`};
    }
    return {ok:true};
  }
  async function pVerifyLock(tx){
    if(!tx.consumes?.length) return {ok:false,r:'No consumed sources'};
    const lock=tx.lock;
    for(const cid of tx.consumes) if(P.consumed.has(cid)) return {ok:false,r:`DOUBLE-SPEND: ${cid.slice(0,12)}...`};
    const srcs=[];
    for(const cid of tx.consumes){
      const local=P.outputs.get(cid);
      if(local){ srcs.push(local); }
      else {
        const carried=(tx.source_outputs||[]).find(s=>s.id===cid);
        if(!carried) return {ok:false,r:`Source ${cid.slice(0,12)}... not in proof state`};
        const ec=await verifyOutputExistence(carried,0,P.outputs);
        if(!ec.ok) return {ok:false,r:`Existence proof failed: ${ec.reason}`};
        srcs.push(carried);
      }
    }
    for(const src of srcs) if(src.owner_pubkey.x!==tx.from_pubkey.x||src.owner_pubkey.y!==tx.from_pubkey.y) return {ok:false,r:'AUTHORIZATION FAILURE'};
    const expLockId=await lockId(lock.source_id,lock.owner_pubkey.x,lock.counterparty_pubkey.x,lock.amount,lock.symbol,lock.terms_hash,lock.expiry);
    if(expLockId!==lock.id) return {ok:false,r:'Lock ID mismatch'};
    const sigBody={consumes:tx.consumes,lock_id:lock.id,creates_change_ids:tx.creates_change.map(o=>o.id),from_sid:tx.from_sid,ts:tx.ts};
    if(!await verify(tx.from_pubkey,sigBody,tx.sig)) return {ok:false,r:'Invalid signature'};
    const inT=srcs.reduce((s,o)=>s+o.amount,0), outT=lock.amount+tx.creates_change.reduce((s,o)=>s+o.amount,0);
    if(inT!==outT) return {ok:false,r:`CONSERVATION: in=${inT} lock+change=${outT}`};
    return {ok:true};
  }
  async function pVerifyResolve(tx){
    const lock=tx.lock_snapshot;
    for(const lid of tx.consumes_lock) if(P.consumed.has(lid)) return {ok:false,r:`DOUBLE-RESOLVE: ${lid.slice(0,12)}...`};
    if(lock.owner_pubkey.x!==tx.from_pubkey.x||lock.owner_pubkey.y!==tx.from_pubkey.y) return {ok:false,r:'AUTHORIZATION FAILURE: not lock owner'};
    const window_expired_p = Date.now() > lock.expiry;
    if(!window_expired_p) return {ok:false,r:'PREMATURE RESOLVE: window not expired'};
    const sigBody={type:'RESOLVE',consumes_lock:tx.consumes_lock,resolution:tx.resolution,creates_ids:tx.creates.map(o=>o.id),from_sid:tx.from_sid,ts:tx.ts};
    if(!await verify(tx.from_pubkey,sigBody,tx.sig)) return {ok:false,r:'Invalid signature'};
    if(tx.resolution==='SLASH'){if(tx.creates.length!==0) return {ok:false,r:'SLASH must create 0 outputs'};}
    else{
      if(tx.creates.length!==1) return {ok:false,r:'Must create 1 output'};
      if(tx.creates[0].amount!==lock.amount) return {ok:false,r:`CONSERVATION: lock=${lock.amount} output=${tx.creates[0].amount}`};
      if(tx.resolution==='RELEASE'&&(tx.creates[0].owner_pubkey.x!==lock.owner_pubkey.x||tx.creates[0].owner_pubkey.y!==lock.owner_pubkey.y)) return {ok:false,r:'RELEASE output not bound to owner pubkey'};
      if(tx.resolution==='AWARD'&&(tx.creates[0].owner_pubkey.x!==lock.counterparty_pubkey.x||tx.creates[0].owner_pubkey.y!==lock.counterparty_pubkey.y)) return {ok:false,r:'AWARD output not bound to counterparty pubkey'};
    }
    return {ok:true};
  }

  try{
    await step('info','Setup: generating fresh keypairs for genesis authority, Alice, Bob, Carol','All WebCrypto P-256. Fully isolated proof state — no wallet CONSUMED or OUTPUTS are used.');

    const mkKP=async()=>{
      const kp=await crypto.subtle.generateKey({name:'ECDSA',namedCurve:'P-256'},true,['sign','verify']);
      const pub=await crypto.subtle.exportKey('jwk',kp.publicKey);
      const sid=(await sha256(JSON.stringify(pub))).slice(0,8);
      return {priv:kp.privateKey,pub,sid};
    };
    const G=await mkKP(), A=await mkKP(), B=await mkKP(), C=await mkKP();
    await step('pass','Keypairs ready',`G:${G.sid} A:${A.sid} B:${B.sid} C:${C.sid}`);

    // ── GENESIS ──
    await w(60);
    await step('info','─── 1. Genesis authority issues output for Alice ───','');
    const gSalt=rSalt();
    const gId=await outputId('GENESIS_ROOT',A.pub.x,1000,'ATT',gSalt,'genesis');
    const gBody={id:gId,source_id:'GENESIS_ROOT',owner_sid:A.sid,owner_pubkey:A.pub,amount:1000,symbol:'ATT',salt:gSalt,type:'genesis'};
    const gSig=await sign(G.priv,gBody);
    // Verify with genesis authority pub — correct
    const gSigOk=await verify(G.pub,gBody,gSig);
    // Verify with Alice's pub — should fail
    const gSigWrong=await verify(A.pub,gBody,gSig);
    await step(gSigOk&&!gSigWrong?'pass':'fail','Genesis authority signature check',
      `Verify with genesis_authority_pub: <span class="${gSigOk?'hlg':'hlr'}">${gSigOk}</span> (required: true)<br>Verify with wrong key (Alice's): <span class="${!gSigWrong?'hlg':'hlr'}">${gSigWrong}</span> (required: false)`);
    if(!gSigOk||gSigWrong){ errors++; }

    // Fraudulent genesis (wrong authority sig)
    const fraudSig=await sign(B.priv,gBody); // Bob signs genesis body
    const fraudAccepted=await verify(G.pub,gBody,fraudSig);
    await step(!fraudAccepted?'block':'fail','Fraudulent genesis (signed by non-authority) rejected',
      `Sig by non-authority (Bob): <span class="hlr">${fraudAccepted}</span> (required: false) → genesis claim rejected`);
    if(fraudAccepted) errors++;

    P.consumed.add(gId);
    const aSalt=rSalt();
    const aId=await outputId(gId,A.pub.x,1000,'ATT',aSalt,'genesis-claim');
    // Attach existence proof — genesis authority sig is the trust anchor
    const aOut={id:aId,source_id:gId,owner_sid:A.sid,owner_pubkey:A.pub,amount:1000,symbol:'ATT',salt:aSalt,type:'genesis-claim',
      _proof:{type:'GENESIS', genesis_output:{...gBody, sig:gSig, genesis_authority_pub:G.pub}}};
    P.outputs.set(aId,aOut);
    await step('pass','Alice claims genesis: genesis consumed, spendable output created',
      `SPENDABLE: <span class="hl">${aId.slice(0,14)}...</span> (1000 ATT) owner: <span class="hl">A.pub.x</span>`);

    // ── SPEND with correct recipient pubkey ──
    await w(60);
    await step('info','─── 2. Spend with correct ownership binding: Alice → Bob (300 ATT) ───','');
    const bSalt=rSalt(), chSalt=rSalt();
    const bId=await outputId(aId,B.pub.x,300,'ATT',bSalt,'spendable');
    const chId=await outputId(aId,A.pub.x,700,'ATT',chSalt,'change');
    const bOut={id:bId,source_id:aId,owner_sid:B.sid,owner_pubkey:B.pub,amount:300,symbol:'ATT',salt:bSalt,type:'spendable'};
    const chOut={id:chId,source_id:aId,owner_sid:A.sid,owner_pubkey:A.pub,amount:700,symbol:'ATT',salt:chSalt,type:'change'};
    const t1Ts=Date.now();
    const t1_sb={consumes:[aId],creates_ids:[bId,chId],from_sid:A.sid,ts:t1Ts};
    const t1_sig=await sign(A.priv,t1_sb);
    const t1={type:'SPEND',v:4,consumes:[aId],source_outputs:[aOut],creates:[bOut,chOut],from_sid:A.sid,from_pubkey:A.pub,memo:'',ts:t1Ts,sig:t1_sig};
    const t1_r=await pVerifySpend(t1);
    await step(t1_r.ok?'pass':'fail','T1 verified: ownership bound to B.pub (300 ATT), conservation 1000=300+700',
      `from_pubkey === source.owner_pubkey: <span class="hlg">${A.pub.x===aOut.owner_pubkey.x}</span><br>Bob output bound to B.pub.x: <span class="hlg">${bOut.owner_pubkey.x===B.pub.x}</span><br>Conservation: 1000 in = 300+700 = <span class="hlg">1000</span> ✓<br>Result: <span class="${t1_r.ok?'hlg':'hlr'}">${t1_r.ok?'ACCEPTED':t1_r.r}</span>`);
    if(!t1_r.ok) errors++;
    P.consumed.add(aId);
    // STEP 3d: Full proof-hop data (matches buildSpendTx backfill)
    bOut._proof={type:'SPEND', source_output:aOut, sig:t1_sig, from_pubkey:A.pub, from_sid:A.sid, ts:t1Ts, creates_ids:[bId,chId]};
    chOut._proof={type:'SPEND', source_output:aOut, sig:t1_sig, from_pubkey:A.pub, from_sid:A.sid, ts:t1Ts, creates_ids:[bId,chId]};
    P.outputs.set(bId,bOut); P.outputs.set(chId,chOut);

    // ── DOUBLE-SPEND ──
    await w(60);
    const t2_same={...t1, ts:Date.now()};
    const t2_r=await pVerifySpend(t2_same);
    await step(t2_r.ok?'fail':'block','T2: double-spend of aId — REJECTED at Rule 1 (before any crypto)',
      `consumed.has(aId): <span class="hlr">true</span> → rejected before sig check<br>Result: <span class="${!t2_r.ok?'hlg':'hlr'}">${t2_r.ok?'WRONGLY ACCEPTED':t2_r.r}</span>`);
    if(t2_r.ok) errors++;

    // ── AUTHORIZATION FAILURE: wrong signer ──
    await w(60);
    await step('info','─── 3. Authorization: Bob attempts to spend Alice\'s change output ───','');
    const theftTs=Date.now();
    const theft_sb={consumes:[chId],creates_ids:[bId],from_sid:B.sid,ts:theftTs};
    const theft_sig=await sign(B.priv,theft_sb); // Bob signs
    // Manually build a transaction claiming to spend chOut but signed by Bob
    const theft_tx={type:'SPEND',v:4,consumes:[chId],source_outputs:[chOut],creates:[{...bOut}],from_sid:B.sid,from_pubkey:B.pub,ts:theftTs,sig:theft_sig,memo:''};
    const theft_r=await pVerifySpend(theft_tx);
    await step(!theft_r.ok?'block':'fail','Bob attempts theft of Alice\'s change: REJECTED at Rule 2 (authorization)',
      `from_pubkey (B.pub.x): <span class="hlr">${B.pub.x.slice(0,16)}...</span><br>source.owner_pubkey.x (A.pub.x): <span class="hl">${A.pub.x.slice(0,16)}...</span><br>Match: <span class="hlr">false</span> → authorization failure<br>Result: <span class="${!theft_r.ok?'hlg':'hlr'}">${theft_r.ok?'WRONGLY ACCEPTED':theft_r.r}</span>`);
    if(theft_r.ok) errors++;

    // ── CONSERVATION FRAUD ──
    await w(60);
    await step('info','─── 4. Conservation: Alice creates more outputs than source ───','');
    const inf_salt=rSalt();
    const inf_id=await outputId(chId,A.pub.x,9999,'ATT',inf_salt,'spendable'); // inflated
    const inf_out={id:inf_id,source_id:chId,owner_sid:A.sid,owner_pubkey:A.pub,amount:9999,symbol:'ATT',salt:inf_salt,type:'spendable'};
    const infTs=Date.now();
    const inf_sb={consumes:[chId],creates_ids:[inf_id],from_sid:A.sid,ts:infTs};
    const inf_sig=await sign(A.priv,inf_sb);
    const inf_tx={type:'SPEND',v:4,consumes:[chId],source_outputs:[chOut],creates:[inf_out],from_sid:A.sid,from_pubkey:A.pub,ts:infTs,sig:inf_sig,memo:''};
    const inf_r=await pVerifySpend(inf_tx);
    await step(!inf_r.ok?'block':'fail','Conservation violation (700 in, 9999 out) rejected at Rule 4',
      `Source: 700 ATT · Output claimed: 9999 ATT · Δ: 9299<br>Result: <span class="${!inf_r.ok?'hlg':'hlr'}">${inf_r.ok?'WRONGLY ACCEPTED':inf_r.r}</span>`);
    if(inf_r.ok) errors++;

    // ── LOCK ──
    await w(60);
    await step('info','─── 5. Lock: Alice locks change output with Carol as counterparty ───','Counterparty pubkey (C.pub) embedded in lock ID and stored in lock object.');
    const lkTerms='deliver-widget-Q3';
    const lkHash=await sha256(lkTerms);
    const lkExpiry=Date.now()-500; // already expired for proof — tests resolution immediately
    const lkId=await lockId(chId,A.pub.x,C.pub.x,700,'ATT',lkHash,lkExpiry);
    const lkObj={id:lkId,source_id:chId,owner_sid:A.sid,owner_pubkey:A.pub,counterparty_sid:C.sid,counterparty_pubkey:C.pub,amount:700,symbol:'ATT',terms_hash:lkHash,terms_raw:lkTerms,expiry:lkExpiry,type:'LOCKED'};
    const lkTs=Date.now();
    const lkSigBody={consumes:[chId],lock_id:lkId,creates_change_ids:[],from_sid:A.sid,ts:lkTs};
    const lkSig=await sign(A.priv,lkSigBody);
    const lkTx={type:'LOCK',v:4,consumes:[chId],source_outputs:[chOut],lock:lkObj,creates_change:[],from_sid:A.sid,from_pubkey:A.pub,ts:lkTs,sig:lkSig};
    const lk_r=await pVerifyLock(lkTx);
    await step(lk_r.ok?'lock':'fail','Lock transition verified: chId consumed, counterparty pubkey C.pub bound into lock ID',
      `Lock ID: <span class="hli">${lkId.slice(0,16)}...</span><br>Lock ID includes C.pub.x: <span class="hlg">verified via lockId() hash</span><br>Conservation: 700 source = 700 locked + 0 change ✓<br>Result: <span class="${lk_r.ok?'hlg':'hlr'}">${lk_r.ok?'ACCEPTED':lk_r.r}</span>`);
    if(!lk_r.ok) errors++;
    P.consumed.add(chId); P.locks.set(lkId,lkObj);

    // Try to spend chOut again (now locked/consumed)
    const lk_ds_r=await pVerifySpend({...inf_tx, consumes:[chId], source_outputs:[chOut]});
    await step(!lk_ds_r.ok?'block':'fail','Locked source cannot be double-spent',
      `consumed.has(chId): <span class="hlr">true</span> → rejected<br>Result: <span class="${!lk_ds_r.ok?'hlg':'hlr'}">${lk_ds_r.ok?'WRONGLY ACCEPTED':lk_ds_r.r}</span>`);
    if(lk_ds_r.ok) errors++;

    // ── PREMATURE RESOLVE ──
    await w(60);
    await step('info','─── 6. Premature resolve rejected (window not expired) ───','');
    const futureExpiry=Date.now()+3600000;
    const lkFuture={...lkObj, expiry:futureExpiry, id: await lockId(chId,A.pub.x,C.pub.x,700,'ATT',lkHash,futureExpiry)};
    P.locks.set(lkFuture.id,lkFuture);
    const preTs=Date.now();
    const preSb={type:'RESOLVE',consumes_lock:[lkFuture.id],resolution:'AWARD',creates_ids:[],from_sid:A.sid,ts:preTs};
    const preSig=await sign(A.priv,preSb);
    const preTx={type:'RESOLVE',v:4,consumes_lock:[lkFuture.id],lock_snapshot:lkFuture,resolution:'AWARD',creates:[],from_sid:A.sid,from_pubkey:A.pub,ts:preTs,challenge_window_expired:false,sig:preSig};
    const pre_r=await pVerifyResolve(preTx);
    await step(!pre_r.ok?'block':'fail','Premature resolve rejected: challenge_window_expired=false',
      `lock.expiry: ${new Date(futureExpiry).toLocaleString()}<br>challenge_window_expired: <span class="hlr">false</span><br>Result: <span class="${!pre_r.ok?'hlg':'hlr'}">${pre_r.ok?'WRONGLY ACCEPTED':pre_r.r}</span>`);
    if(pre_r.ok) errors++;

    // ── RESOLVE AWARD with correct counterparty pubkey ──
    await w(60);
    await step('info','─── 7. RESOLVE(AWARD): output bound to C.pub, not resolver\'s pub ───','');
    // Award output must use C.pub — that's what\'s stored in the lock
    const awSalt=rSalt();
    const awId=await outputId(lkId,C.pub.x,700,'ATT',awSalt,'spendable'); // C.pub here — correct
    const awOut={id:awId,source_id:lkId,owner_sid:C.sid,owner_pubkey:C.pub,amount:700,symbol:'ATT',salt:awSalt,type:'spendable'};
    const awTs=Date.now();
    const awSb={type:'RESOLVE',consumes_lock:[lkId],resolution:'AWARD',creates_ids:[awId],from_sid:A.sid,ts:awTs};
    const awSig=await sign(A.priv,awSb);
    const awTx={type:'RESOLVE',v:4,consumes_lock:[lkId],lock_snapshot:lkObj,resolution:'AWARD',creates:[awOut],from_sid:A.sid,from_pubkey:A.pub,ts:awTs,challenge_window_expired:true,sig:awSig};
    const aw_r=await pVerifyResolve(awTx);
    await step(aw_r.ok?'resolve':'fail','AWARD verified: output is bound to C.pub (counterparty), not A.pub (resolver)',
      `award output.owner_pubkey.x: <span class="hli">${C.pub.x.slice(0,16)}...</span> = C.pub ✓<br>lock.counterparty_pubkey.x: <span class="hli">${lkObj.counterparty_pubkey.x.slice(0,16)}...</span><br>Match: <span class="${C.pub.x===lkObj.counterparty_pubkey.x?'hlg':'hlr'}">${C.pub.x===lkObj.counterparty_pubkey.x}</span><br>Result: <span class="${aw_r.ok?'hlg':'hlr'}">${aw_r.ok?'ACCEPTED':aw_r.r}</span>`);
    if(!aw_r.ok) errors++;
    P.consumed.add(lkId);

    // Now verify that AWARD would fail if output were bound to resolver's pubkey instead
    const wrongAwardSalt=rSalt();
    const wrongAwardId=await outputId(lkId,A.pub.x,700,'ATT',wrongAwardSalt,'spendable'); // A.pub — wrong!
    const wrongAwardOut={id:wrongAwardId,source_id:lkId,owner_sid:A.sid,owner_pubkey:A.pub,amount:700,symbol:'ATT',salt:wrongAwardSalt,type:'spendable'};
    const waTs=Date.now();
    const waSb={type:'RESOLVE',consumes_lock:[lkId],resolution:'AWARD',creates_ids:[wrongAwardId],from_sid:A.sid,ts:waTs};
    const waSig=await sign(A.priv,waSb);
    const waTx={type:'RESOLVE',v:4,consumes_lock:[lkId],lock_snapshot:lkObj,resolution:'AWARD',creates:[wrongAwardOut],from_sid:A.sid,from_pubkey:A.pub,ts:waTs,challenge_window_expired:true,sig:waSig};
    P.consumed.delete(lkId); // temporarily unmark to test this path
    const wa_r=await pVerifyResolve(waTx);
    P.consumed.add(lkId); // re-mark
    await step(!wa_r.ok?'block':'fail','AWARD with resolver\'s pubkey instead of counterparty\'s — REJECTED',
      `output.owner_pubkey.x: <span class="hlr">${A.pub.x.slice(0,16)}...</span> = A.pub (WRONG)<br>Expected: <span class="hli">${C.pub.x.slice(0,16)}...</span> = C.pub<br>Result: <span class="${!wa_r.ok?'hlg':'hlr'}">${wa_r.ok?'WRONGLY ACCEPTED':wa_r.r}</span>`);
    if(wa_r.ok) errors++;

    // ── DOUBLE-RESOLVE ──
    await w(60);
    const dr_r=await pVerifyResolve({...awTx});
    await step(!dr_r.ok?'block':'fail','Double-resolve rejected: lock already consumed',
      `P.consumed.has(lkId): <span class="hlr">true</span> → rejected before sig check<br>Result: <span class="${!dr_r.ok?'hlg':'hlr'}">${dr_r.ok?'WRONGLY ACCEPTED':dr_r.r}</span>`);
    if(dr_r.ok) errors++;

    // ── SLASH ──
    await w(60);
    await step('info','─── 8. RESOLVE(SLASH): burns funds, creates 0 outputs ───','');
    const slLkId=await lockId(awId,C.pub.x,A.pub.x,700,'ATT',lkHash,Date.now()-1);
    const slLk={id:slLkId,source_id:awId,owner_sid:C.sid,owner_pubkey:C.pub,counterparty_sid:A.sid,counterparty_pubkey:A.pub,amount:700,symbol:'ATT',terms_hash:lkHash,terms_raw:lkTerms,expiry:Date.now()-1,type:'LOCKED'};
    P.locks.set(slLkId,slLk);
    const slTs=Date.now();
    const slSb={type:'RESOLVE',consumes_lock:[slLkId],resolution:'SLASH',creates_ids:[],from_sid:C.sid,ts:slTs};
    const slSig=await sign(C.priv,slSb);
    const slTx={type:'RESOLVE',v:4,consumes_lock:[slLkId],lock_snapshot:slLk,resolution:'SLASH',creates:[],from_sid:C.sid,from_pubkey:C.pub,ts:slTs,challenge_window_expired:true,sig:slSig};
    const sl_r=await pVerifyResolve(slTx);
    await step(sl_r.ok?'resolve':'fail','SLASH verified: 0 outputs created, funds destroyed',
      `creates: [] · SLASH conservation: no requirement (explicit burn)<br>Result: <span class="${sl_r.ok?'hlg':'hlr'}">${sl_r.ok?'ACCEPTED':sl_r.r}</span>`);
    if(!sl_r.ok) errors++;

    // Verify SLASH with non-zero creates fails
    const slBadTs=Date.now();
    const slBadSb={type:'RESOLVE',consumes_lock:[slLkId],resolution:'SLASH',creates_ids:[awId],from_sid:C.sid,ts:slBadTs};
    const slBadSig=await sign(C.priv,slBadSb);
    const slBadTx={...slTx,creates:[awOut],ts:slBadTs,sig:slBadSig};
    P.consumed.delete(slLkId);
    const slBad_r=await pVerifyResolve(slBadTx);
    P.consumed.add(slLkId);
    await step(!slBad_r.ok?'block':'fail','SLASH with outputs rejected (SLASH must create 0)',
      `Result: <span class="${!slBad_r.ok?'hlg':'hlr'}">${slBad_r.ok?'WRONGLY ACCEPTED':slBad_r.r}</span>`);
    if(slBad_r.ok) errors++;

    // ── CROSS-WALLET: Bob receives from Alice using proof chain ──
    await w(80);
    await step('info',"─── 9. Cross-wallet: Bob (empty state) accepts Alice's transition via ancestry proof ───",
      "Bob has no prior local state. Alice's transition carries aOut with _proof={type:GENESIS,...}. Bob walks the chain: genesis authority sig verified → aOut proven → accept T1.");

    const P2={consumed:new Set(),outputs:new Map(),locks:new Map()};

    // Fix: swap genesis authority to test's authority so cross-wallet verification
    // doesn't reject the test genesis as "unknown authority"
    const savedGA = GENESIS_AUTHORITY_PUB;
    GENESIS_AUTHORITY_PUB = G.pub;

    try {
    // Verify aOut existence from empty state
    const xwExist=await verifyOutputExistence(aOut,0,P2.outputs);
    await step(xwExist.ok?'pass':'fail','Bob: verifyOutputExistence(aOut) with empty local state',
      `P2.outputs.has(aId): <span class="hlr">false</span> → walks _proof chain<br>`+
      `aOut._proof.type: <span class="hl">GENESIS</span><br>`+
      `genesis_authority_pub: G.pub · sig: verified by verifyOutputExistence<br>`+
      `aOut.source_id === genesis_output.id: <span class="${aOut.source_id===gId?'hlg':'hlr'}">${aOut.source_id===gId}</span><br>`+
      `Result: <span class="${xwExist.ok?'hlg':'hlr'}">${xwExist.ok?'EXISTS':'FAILED: '+xwExist.reason}</span>`);
    if(!xwExist.ok) errors++;

    // Build a fresh T1-equivalent for cross-wallet test
    const xwTs=Date.now();
    const xwSb={consumes:[aId],creates_ids:[bId,chId],from_sid:A.sid,ts:xwTs};
    const xwSig=await sign(A.priv,xwSb);
    const xwTx={type:'SPEND',v:4,consumes:[aId],source_outputs:[aOut],creates:[bOut,chOut],from_sid:A.sid,from_pubkey:A.pub,memo:'',ts:xwTs,sig:xwSig};

    // Use pVerifySpend but with P2 state — temporarily swap P reference
    const origP={consumed:P.consumed,outputs:P.outputs,locks:P.locks};
    P.consumed=P2.consumed; P.outputs=P2.outputs; P.locks=P2.locks;
    let xwResult;
    try {
      xwResult=await pVerifySpend(xwTx);
    } finally {
      P.consumed=origP.consumed; P.outputs=origP.outputs; P.locks=origP.locks;
    }

    await step(xwResult.ok?'pass':'fail','Bob: pVerifySpend passes all 4 rules from empty state',
      `Rule 1 — consumed: <span class="${!P2.consumed.has(aId)?'hlg':'hlr'}">clean</span><br>`+
      `Rule 2 — existence: genesis proof chain verified ✓<br>`+
      `Rule 3 — signature: Alice ECDSA sig ✓<br>`+
      `Rule 4 — conservation: 1000=300+700 ✓<br>`+
      `Result: <span class="${xwResult.ok?'hlg':'hlr'}">${xwResult.ok?'ACCEPTED':'REJECTED: '+xwResult.r}</span>`);
    if(!xwResult.ok) errors++;

    if(xwResult.ok){
      P2.consumed.add(aId);
      // STEP 3c: Bob stores full proof-hop (matches acceptTx fix)
      const bobReceived={...bOut, _proof:{type:'SPEND',source_output:aOut,sig:xwSig,from_pubkey:A.pub,from_sid:A.sid,ts:xwTs,creates_ids:[bId,chId]}};
      P2.outputs.set(bId, bobReceived);
      await step('pass','Bob stores bob_output · full proof chain: GENESIS ← aOut ← bobOut (2 hops)',
        `Bob's balance: 300 ATT · chain depth: 2 · double-spend: impossible (aId in P2.consumed)`);
    }

    } finally {
      // Restore real genesis authority after cross-wallet test — even if exception
      GENESIS_AUTHORITY_PUB = savedGA;
    }

    // ── SUMMARY ──
    await w(200);
    const sum=document.getElementById('proof-summary');
    sum.style.display='block';
    sum.className='proof-summary '+(errors===0?'pass':'fail');
    document.getElementById('ps-title').textContent=errors===0?'All v4 Rules Verified':''+errors+' Rule(s) Failed';
    document.getElementById('ps-detail').innerHTML=errors===0
      ?`<strong>Rule 1 — Consumed-source check:</strong> double-spend rejected before any crypto ✓<br>
        <strong>Rule 2 — Authorization:</strong> signer must own consumed source (pubkey.x match) ✓<br>
        &nbsp;&nbsp;→ Unauthorized spend by non-owner rejected ✓<br>
        &nbsp;&nbsp;→ Fraudulent genesis (wrong authority) rejected ✓<br>
        <strong>Rule 3 — Signature:</strong> ECDSA over transition body ✓<br>
        <strong>Rule 4 — Conservation:</strong> Σ inputs === Σ outputs enforced ✓<br>
        &nbsp;&nbsp;→ Inflation attempt (700 in → 9999 out) rejected ✓<br>
        <strong>Lock invariants:</strong><br>
        &nbsp;&nbsp;→ Counterparty pubkey bound into lock ID ✓<br>
        &nbsp;&nbsp;→ Locked source cannot be double-spent ✓<br>
        &nbsp;&nbsp;→ Premature resolve rejected (window not expired) ✓<br>
        <strong>Resolve invariants:</strong><br>
        &nbsp;&nbsp;→ AWARD output bound to counterparty pubkey (not resolver's) ✓<br>
        &nbsp;&nbsp;→ AWARD with wrong pubkey rejected ✓<br>
        &nbsp;&nbsp;→ Double-resolve rejected ✓<br>
        &nbsp;&nbsp;→ SLASH creates 0 outputs ✓<br>
        &nbsp;&nbsp;→ SLASH with outputs rejected ✓`
      :`${errors} rule(s) failed. Review steps above.`;

  }catch(err){
    await step('fail','Proof exception',err.message);
    const sum=document.getElementById('proof-summary');
    sum.style.display='block'; sum.className='proof-summary fail';
    document.getElementById('ps-title').textContent='Exception';
    document.getElementById('ps-detail').textContent=err.message;
  }
  document.getElementById('proof-btn').disabled=false;
  document.getElementById('proof-btn').textContent='▶ Run Full v4 Proof';
  proofRunning=false;
}

function clearProof(){
  document.getElementById('proof-steps').innerHTML='';
  const s=document.getElementById('proof-summary');
  s.style.display='none'; s.className='proof-summary';
}

// ── UI ──
function sw(name){
  const names=['balance','sources','send','lock','resolve','settlement','genesis','receive','proof','log'];
  document.querySelectorAll('.tab').forEach((t,i)=>t.classList.toggle('active',names[i]===name));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.getElementById('panel-'+name).classList.add('active');
  if(['send','lock','resolve'].includes(name)) populateSels();
}
function copySid(){ if(!SID)return; navigator.clipboard.writeText(SID).then(()=>toast('SID copied','ok')); }
function copyAddr(){
  const s=document.getElementById('addr-share').textContent;
  if(s&&s!=='—') navigator.clipboard.writeText(s).then(()=>toast('Address copied','ok'));
}
function copyStr(id){ navigator.clipboard.writeText(document.getElementById(id).textContent).then(()=>toast('Copied','ok')); }
function broadcastStr(id){
  const s=document.getElementById(id).textContent;
  try{
    const tx=JSON.parse(atob(s.replace(/^NX4:/,'')));
    if(mounted && _kernelPort){
      // FIX 4: Route through private kernel port
      _kernelPort.postMessage({type:'EMIT',channel:'nexus.v4.transition',payload:{type:'TRANSITION',tx}});
      log('Transition emitted via kernel MessagePort','info');
    } else {
      // Kernel not mounted — fall back to direct channel (standalone / file:// context)
      BC_V4.postMessage({type:'TRANSITION',tx});
      log('Transition emitted via direct channel (kernel not mounted)','warn');
    }
    toast('Broadcast','ok');
  }catch(e){ toast('Parse error: '+e.message,'err'); }
}
function log(msg,cls=''){
  const el=document.getElementById('log');
  const t=new Date().toLocaleTimeString('en',{hour12:false,hour:'2-digit',minute:'2-digit',second:'2-digit'});
  const d=document.createElement('div'); d.className='le '+cls; d.textContent='['+t+'] '+msg;
  el.appendChild(d); el.scrollTop=el.scrollHeight;
}
function clearLog(){ document.getElementById('log').innerHTML=''; }
let _tt;
function toast(msg,type=''){
  const el=document.getElementById('toast'); el.textContent=msg; el.className='show t-'+type;
  clearTimeout(_tt); _tt=setTimeout(()=>el.className='',2500);
}
// Receive panel alias
const addr_receive_el = {textContent:''};
Object.defineProperty(addr_receive_el,'textContent',{set(v){const e=document.getElementById('addr-share');if(e)e.textContent=v;},get(){return document.getElementById('addr-share')?.textContent||'';}});

// Incoming
BC_V4.onmessage=async e=>{
  const m=e.data; if(!m||m.type!=='TRANSITION') return;
  const tx=m.tx;
  if(!SID) return; // not booted yet
  if(!txIsForMe(tx)) return;
  if(txAlreadyConsumed(tx)) return; // already accepted
  // Avoid duplicate PENDING entries
  const already=PENDING.some(p=>{
    const pids=(p.consumes||[]).concat(p.consumes_lock||[]).join(',');
    const tids=(tx.consumes||[]).concat(tx.consumes_lock||[]).join(',');
    return pids===tids;
  });
  if(already) return;
  PENDING.push(tx); renderPending();
  toast('⬡ Incoming '+tx.type+' from '+tx.from_sid,'ok');
};
function showIncomingBadge() {
  // Flash tab title so user notices in another tab
  const orig = document.title;
  let n = 0;
  const interval = setInterval(() => {
    document.title = n++ % 2 === 0 ? `⬡ INCOMING [${WALLET_SLOT}]` : orig;
    if (n > 6) { clearInterval(interval); document.title = orig; }
  }, 500);
  // Navigate to Balance panel so incoming card is visible
  const currentActive = document.querySelector('.tab.active');
  if (currentActive && !['balance','Balance'].includes(currentActive.textContent.trim())) {
    sw('balance');
  }
}

function renderPending(){
  const card=document.getElementById('incoming-card');
  const list=document.getElementById('incoming-list');
  document.getElementById('inc-badge').textContent=PENDING.length+' pending';
  card.style.display=PENDING.length?'block':'none';
  if(PENDING.length) showIncomingBadge();
  list.innerHTML=PENDING.map((tx,i)=>{
    const myOuts=(tx.creates||[]).filter(o=>o.owner_sid===SID);
    const myAmt=myOuts.reduce((s,o)=>s+o.amount,0);
    const isLock=tx.type==='LOCK';
    const dispAmt=isLock&&tx.lock?.counterparty_sid===SID?tx.lock.amount:myAmt;
    return `<div class="inc-item">
    <div class="inc-header"><div class="inc-from">From: ${tx.from_sid} · ${tx.type}</div>
    <div class="inc-amt">${fmt(dispAmt)||'?'} ${TOKEN_SYM}</div></div>
    <div style="font-size:9px;color:var(--dim);margin-bottom:6px">Consumes: ${(tx.consumes||tx.consumes_lock||[]).map(id=>id.slice(0,10)+'...').join(', ')}</div>
    <div class="btn-row"><button class="btn btn-sm" onclick="acceptPI(${i})">✓ Accept</button><button class="btn btn-sm btn-ghost" onclick="rejectPI(${i})">Reject</button></div>
  </div>`;}).join('');
}
async function acceptPI(i){ const tx=PENDING[i]; PENDING.splice(i,1); await acceptTx(tx); renderPending(); }
function rejectPI(i){ PENDING.splice(i,1); renderPending(); toast('Rejected','warn'); }

// ═══════════════════════════════════════════════════════════════
// KERNEL IPC — FIX 4: MessagePort (private) replaces BroadcastChannel (public)
// FIX 1: Watchdog detects kernel death and falls back automatically
// ═══════════════════════════════════════════════════════════════

// When running inside Nexus OS as an iframe block, the kernel sends a BOOT
// message via window.postMessage with a MessagePort attached. That port is
// a private pipe — only this wallet and the kernel can read it.
// When running standalone (not in an iframe), this never fires and the
// wallet operates via BroadcastChannel + outbox only.

function initKernelIPC(){
  // Are we in an iframe? If window === window.top, we're standalone.
  if(window === window.top){
    log('Standalone mode — no kernel IPC. Using BroadcastChannel + outbox.','warn');
    return;
  }

  // Listen for BOOT message from kernel — carries the private MessagePort
  window.addEventListener('message', function(e){
    // SECURITY: Only accept BOOT from the parent frame (the kernel).
    // Sibling iframes share our origin but are NOT the kernel.
    // e.source is unforgeable — a sibling can't make postMessage appear to come from parent.
    if(e.source !== window.parent) return;
    if(!e.data || e.data.type !== 'BOOT') return;
    _kernelPort = e.ports[0];
    if(!_kernelPort) { log('BOOT received but no port attached','warn'); return; }

    log('BOOT received — private kernel port established','ok');

    _kernelPort.onmessage = function(ev){
      const msg = ev.data;
      if(!msg || !msg.type) return;

      switch(msg.type){

        case 'MOUNT_CHALLENGE':
          // Echo nonce exactly — wrong nonce = violation = eviction
          _kernelPort.postMessage({ type: 'MOUNT_ACK', nonce: msg.nonce });
          if(!mounted){
            mounted = true;
            _lastPing = Date.now();
            startWatchdog();
            document.getElementById('hdot').className='hdot live';
            log('Kernel: mounted (MessagePort, private channel)','ok');
          }
          break;

        case 'PING':
          // FIX 1: Record timestamp for watchdog
          _lastPing = Date.now();
          _kernelPort.postMessage({ type: 'PONG', nonce: msg.nonce });
          break;

        case 'MSG':
          // Incoming message from another block via kernel IPC bus
          if(msg.channel === 'nexus.v4.transition'){
            const payload = msg.payload;
            if(!payload || payload.type !== 'TRANSITION') break;
            const tx = payload.tx;
            const creates = (tx.creates||[]).concat(tx.creates_change||[]);
            if(!creates.some(o=>o.owner_sid===SID) && !(tx.lock?.owner_sid===SID) && !(tx.lock?.counterparty_sid===SID)) break;
            // Dedup against PENDING
            const alreadyQueued = PENDING.some(p => {
              const pids = (p.consumes||[]).concat(p.consumes_lock||[]).join(',');
              const tids = (tx.consumes||[]).concat(tx.consumes_lock||[]).join(',');
              return pids === tids;
            });
            if(!alreadyQueued){
              PENDING.push(tx);
              renderPending();
              toast('Incoming (kernel) '+tx.type,'ok');
              log('Incoming transition via kernel: '+tx.type+' from '+tx.from_sid,'info');
            }
          }
          break;

        // Unknown message types: silently ignore (not a violation from our side)
      }
    };

    _kernelPort.start(); // Required for MessagePort — activates delivery

    // DECLARE — tell the kernel what we emit and consume
    // Must fire synchronously before the 9-second watchdog kills us
    _kernelPort.postMessage({
      type: 'DECLARE',
      manifest: {
        emits:    ['nexus.v4.transition'],
        consumes: ['nexus.v4.transition']
      },
      app: {
        title:       'Wallet v4',
        icon:        '◈',
        description: 'NX4 full-rules wallet — MessagePort secured',
        visible:     true
      }
    });

    log('DECLARE sent on private port','info');

  }, { once: false }); // Keep listener for kernel restart/reload recovery
}

// ── FIX 1: Kernel death watchdog ──
// The kernel PINGs every 3s. If we haven't received a PING in 12s,
// the kernel is probably dead. Set mounted=false so autoTransport
// falls back to BroadcastChannel instead of posting into the void.
function startWatchdog(){
  if(_watchdogInterval) clearInterval(_watchdogInterval);
  _watchdogInterval = setInterval(function(){
    if(mounted && _lastPing > 0 && (Date.now() - _lastPing > WATCHDOG_TIMEOUT_MS)){
      mounted = false;
      _kernelPort = null;
      document.getElementById('hdot').className='hdot';
      log('Watchdog: kernel appears dead — no PING in ' + WATCHDOG_TIMEOUT_MS + 'ms. Falling back to BroadcastChannel.','warn');
      toast('Kernel connection lost — using fallback transport','warn');
      clearInterval(_watchdogInterval);
      _watchdogInterval = null;
    }
  }, 5000); // Check every 5 seconds
}

// ── Standalone BroadcastChannel receiver (BC_V4) ──
// This always runs regardless of kernel mount state.
// Handles direct wallet-to-wallet transitions when there's no kernel.
BC_V4.onmessage = e => {
  if(!SID) return;
  const payload = e.data;
  if(!payload || payload.type !== 'TRANSITION') return;
  const tx = payload.tx;
  if(!txIsForMe(tx)) return;
  if(txAlreadyConsumed(tx)) return;
  const alreadyQueued = PENDING.some(p => {
    const pids = (p.consumes||[]).concat(p.consumes_lock||[]).join(',');
    const tids = (tx.consumes||[]).concat(tx.consumes_lock||[]).join(',');
    return pids === tids;
  });
  if(!alreadyQueued){
    PENDING.push(tx);
    renderPending();
    toast('Incoming (direct) '+tx.type,'ok');
    log('Incoming transition via BC_V4: '+tx.type+' from '+tx.from_sid,'info');
  }
};

window.addEventListener('beforeunload', () => {
  if(_kernelPort){
    try { _kernelPort.postMessage({type: 'LEAVE'}); } catch(e){}
  }
});

boot();
