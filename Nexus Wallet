<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
<title>NEXUS · Wallet v4 · auto</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#060608;--s0:#0c0c10;--s1:#111116;--s2:#18181f;--s3:#22222c;
  --border:#2a2a38;--border-hi:#3d3d52;
  --text:#e2e2ea;--dim:#7a7a96;--muted:#3a3a50;
  --gold:#f5a623;--gold-dim:rgba(245,166,35,.1);--gold-glow:rgba(245,166,35,.22);
  --indigo:#818cf8;--indigo-dim:rgba(129,140,248,.1);
  --cyan:#22d3ee;--cyan-dim:rgba(34,211,238,.08);
  --danger:#f87171;--danger-dim:rgba(248,113,113,.08);
  --green:#4ade80;--green-dim:rgba(74,222,128,.06);
  --amber:#fbbf24;--amber-dim:rgba(251,191,36,.08);
  --mono:'JetBrains Mono',monospace;--serif:'DM Serif Display',serif;--r:6px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:var(--mono);font-size:12px;overflow:hidden}
#app{display:grid;grid-template-rows:52px 38px 1fr;height:100vh}
#topbar{display:flex;align-items:center;gap:12px;padding:0 18px;background:var(--s0);border-bottom:1px solid var(--border)}
#logo{font-family:var(--serif);font-size:20px;color:var(--gold)}
#logo sub{color:var(--dim);font-size:10px;font-family:var(--mono);letter-spacing:.12em;text-transform:uppercase;margin-left:6px;vertical-align:middle}
.hdot{width:7px;height:7px;border-radius:50%;background:var(--muted);transition:background .3s;flex-shrink:0}
.hdot.live{background:var(--green);box-shadow:0 0 8px var(--green)}
#tb-right{margin-left:auto;display:flex;align-items:center;gap:10px}
.bal-chip{display:flex;align-items:baseline;gap:5px;padding:4px 12px;border:1px solid var(--border);background:var(--s1);border-radius:20px}
.bal-chip .amt{font-family:var(--serif);font-size:18px;color:var(--gold)}
.bal-chip .sym{font-size:10px;color:var(--dim);letter-spacing:.1em}
.bal-chip .lk{font-size:10px;color:var(--indigo);margin-left:4px}
.sid-chip{font-size:10px;color:var(--dim);background:var(--s2);padding:3px 8px;border:1px solid var(--border);border-radius:3px;cursor:pointer;transition:border-color .15s}
.sid-chip:hover{border-color:var(--gold);color:var(--gold)}
#tabs{display:flex;background:var(--s0);border-bottom:1px solid var(--border);padding:0 18px;gap:0;align-items:flex-end;overflow-x:auto}
#tabs::-webkit-scrollbar{height:0}
.tab{padding:8px 13px;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;white-space:nowrap;flex-shrink:0}
.tab:hover:not(.active){color:var(--dim)}
.tab.active{color:var(--gold);border-bottom-color:var(--gold)}
#panels{overflow:hidden;height:100%}
.panel{display:none;height:100%;overflow-y:auto;padding:16px;gap:12px;flex-direction:column}
.panel.active{display:flex}
.panel::-webkit-scrollbar{width:4px}
.panel::-webkit-scrollbar-thumb{background:var(--s3)}
.card{background:var(--s1);border:1px solid var(--border);border-radius:var(--r);padding:14px;flex-shrink:0}
.ct{font-size:9px;text-transform:uppercase;letter-spacing:.15em;color:var(--dim);margin-bottom:12px;display:flex;justify-content:space-between;align-items:center}
.badge{font-size:9px;padding:2px 7px;border-radius:3px;font-weight:700;letter-spacing:.06em}
.b-new{background:var(--gold-dim);color:var(--gold);border:1px solid var(--gold-glow)}
.b-ok{background:var(--green-dim);color:var(--green);border:1px solid rgba(74,222,128,.2)}
.b-warn{background:var(--amber-dim);color:var(--amber);border:1px solid rgba(251,191,36,.2)}
.b-danger{background:var(--danger-dim);color:var(--danger);border:1px solid rgba(248,113,113,.2)}
.b-indigo{background:var(--indigo-dim);color:var(--indigo);border:1px solid rgba(129,140,248,.2)}
.bal-hero{display:flex;align-items:baseline;gap:8px;margin:6px 0 10px}
.bal-hero .amount{font-family:var(--serif);font-size:48px;color:var(--gold);line-height:1}
.bal-hero .sym{font-size:16px;color:var(--dim)}
.bal-hero .lksub{font-size:13px;color:var(--indigo);margin-left:4px}
.addr-box{background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:8px 10px;font-size:9px;color:var(--dim);word-break:break-all;line-height:1.7;cursor:pointer;transition:border-color .15s}
.addr-box:hover{border-color:var(--gold)}
.addr-box.copyable::after{content:' ·copy';color:var(--muted);font-size:8px}
.out-card{background:var(--s2);border:1px solid var(--border);border-radius:5px;padding:10px 12px;display:grid;grid-template-columns:1fr auto;gap:4px;margin-bottom:6px;transition:border-color .2s}
.out-card.consumed{opacity:.38}
.out-card.locked-out{border-color:var(--indigo);background:var(--indigo-dim)}
.out-id{font-size:9px;color:var(--muted)}
.out-src{font-size:9px;color:var(--dim)}.out-src span{color:var(--indigo)}
.out-amount{font-family:var(--serif);font-size:22px;color:var(--gold);text-align:right;grid-row:1/4;align-self:center}
.out-amount.lk-color{color:var(--indigo)}.out-amount.cx-color{color:var(--muted)}
.otag{display:inline-block;font-size:8px;text-transform:uppercase;letter-spacing:.1em;padding:1px 5px;border-radius:2px;margin-right:3px}
.otag.genesis{background:var(--cyan-dim);color:var(--cyan);border:1px solid rgba(34,211,238,.2)}
.otag.spendable{background:var(--green-dim);color:var(--green);border:1px solid rgba(74,222,128,.2)}
.otag.change{background:var(--s3);color:var(--dim);border:1px solid var(--border)}
.otag.locked{background:var(--indigo-dim);color:var(--indigo);border:1px solid rgba(129,140,248,.2)}
.otag.consumed{background:var(--danger-dim);color:var(--danger);border:1px solid rgba(248,113,113,.2)}
.field{margin-bottom:10px}
label{display:block;font-size:9px;color:var(--dim);margin-bottom:4px;text-transform:uppercase;letter-spacing:.1em}
input,textarea,select{width:100%;background:var(--s2);border:1px solid var(--border);color:var(--text);font-family:var(--mono);font-size:12px;padding:7px 10px;border-radius:4px;outline:none;transition:border-color .12s}
input:focus,textarea:focus,select:focus{border-color:var(--gold)}
textarea{resize:vertical;min-height:56px;line-height:1.6}
.parsed-addr{font-size:9px;padding:5px 8px;border-radius:3px;margin-top:4px;display:none}
.parsed-addr.ok{background:var(--green-dim);color:var(--green);border:1px solid rgba(74,222,128,.2)}
.parsed-addr.err{background:var(--danger-dim);color:var(--danger);border:1px solid rgba(248,113,113,.2)}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:8px 16px;background:var(--gold-dim);border:1px solid var(--gold);color:var(--gold);font-family:var(--mono);font-size:11px;font-weight:700;cursor:pointer;border-radius:4px;letter-spacing:.06em;transition:all .12s;width:100%;margin-top:4px}
.btn:hover{background:var(--gold-glow)}.btn:disabled{opacity:.3;cursor:not-allowed}
.btn-ghost{border-color:var(--border);color:var(--dim);background:transparent}.btn-ghost:hover{border-color:var(--dim);background:var(--s2)}
.btn-indigo{border-color:var(--indigo);color:var(--indigo);background:var(--indigo-dim)}.btn-indigo:hover{background:rgba(129,140,248,.18)}
.btn-danger{border-color:var(--danger);color:var(--danger);background:var(--danger-dim)}
.btn-sm{padding:4px 10px;font-size:10px;width:auto;margin-top:0}
.btn-row{display:flex;gap:8px}.btn-row .btn{flex:1}
.tx-preview{background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:10px;margin-top:8px}
.tx-line{font-size:9px;color:var(--dim);padding:2px 0;display:flex;gap:8px;align-items:flex-start}
.tx-line .lbl{color:var(--muted);width:80px;flex-shrink:0}
.tx-line .val{color:var(--text);flex:1;word-break:break-all}
.val.gold{color:var(--gold)}.val.grn{color:var(--green)}.val.red{color:var(--danger)}.val.ind{color:var(--indigo)}.val.ok{color:var(--green);font-weight:700}
.tok-out{background:var(--bg);border:1px solid var(--gold);border-radius:4px;padding:10px;margin-top:10px;display:none}
.tok-out.show{display:block;animation:glow .8s ease}
@keyframes glow{0%,100%{box-shadow:none}50%{box-shadow:0 0 20px var(--gold-glow)}}
.tok-str{font-size:9px;color:var(--gold);word-break:break-all;line-height:1.8}
.pstep{display:flex;gap:10px;padding:8px 10px;border-radius:4px;margin-bottom:4px;background:var(--s2);border:1px solid var(--border);align-items:flex-start;animation:fi .22s ease}
@keyframes fi{from{opacity:0;transform:translateY(4px)}}
.pstep.pass{border-color:rgba(74,222,128,.3);background:rgba(74,222,128,.04)}
.pstep.fail{border-color:rgba(248,113,113,.3);background:rgba(248,113,113,.04)}
.pstep.block{border-color:rgba(245,166,35,.3);background:rgba(245,166,35,.04)}
.pstep.lock{border-color:rgba(129,140,248,.3);background:rgba(129,140,248,.04)}
.pstep.resolve{border-color:rgba(34,211,238,.3);background:rgba(34,211,238,.04)}
.pstep.info{border-color:var(--border)}
.psi{font-size:14px;flex-shrink:0;margin-top:1px}.psb{flex:1}
.psl{font-size:11px;color:var(--text);margin-bottom:2px}
.psd{font-size:9px;color:var(--dim);line-height:1.6;word-break:break-all}
.psd .hl{color:var(--gold)}.psd .hlg{color:var(--green)}.psd .hlr{color:var(--danger)}.psd .hli{color:var(--indigo)}.psd .hlc{color:var(--cyan)}
.proof-summary{padding:16px;border-radius:var(--r);margin-top:8px;text-align:center;display:none}
.proof-summary.pass{background:rgba(74,222,128,.06);border:1px solid rgba(74,222,128,.3)}
.proof-summary.fail{background:var(--danger-dim);border:1px solid rgba(248,113,113,.3)}
.ps-title{font-family:var(--serif);font-size:22px;margin-bottom:6px}
.proof-summary.pass .ps-title{color:var(--green)}.proof-summary.fail .ps-title{color:var(--danger)}
.ps-detail{font-size:10px;color:var(--dim);line-height:1.9}
.notice{padding:8px 12px;border-radius:4px;font-size:10px;line-height:1.7;margin-bottom:10px}
.notice.warn{background:var(--amber-dim);border:1px solid rgba(251,191,36,.2);color:var(--amber)}
.notice.info{background:var(--indigo-dim);border:1px solid rgba(129,140,248,.2);color:var(--indigo)}
.notice.ok{background:var(--green-dim);border:1px solid rgba(74,222,128,.2);color:var(--green)}
.notice.err{background:var(--danger-dim);border:1px solid rgba(248,113,113,.2);color:var(--danger)}
.inc-item{background:var(--green-dim);border:1px solid rgba(74,222,128,.2);border-radius:4px;padding:10px;margin-bottom:6px;animation:fi .2s ease}
.inc-header{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:4px}
.inc-amt{font-family:var(--serif);font-size:20px;color:var(--gold)}
.inc-from{font-size:9px;color:var(--dim)}
.log-wrap{background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:8px;min-height:200px;overflow-y:auto}
.log-wrap::-webkit-scrollbar{width:3px}.log-wrap::-webkit-scrollbar-thumb{background:var(--s3)}
.le{font-size:10px;color:var(--dim);padding:2px 0;line-height:1.6}
.le.ok{color:var(--green)}.le.warn{color:var(--gold)}.le.err{color:var(--danger)}.le.info{color:var(--indigo)}.le.lock{color:var(--indigo)}.le.resolve{color:var(--cyan)}
#toast{position:fixed;bottom:18px;right:18px;padding:8px 16px;border-radius:5px;font-size:11px;background:var(--s1);border:1px solid var(--border);color:var(--text);opacity:0;transition:opacity .22s;z-index:9999;pointer-events:none}
#toast.show{opacity:1}
#toast.t-ok{border-color:var(--green);color:var(--green)}
#toast.t-warn{border-color:var(--gold);color:var(--gold)}
#toast.t-err{border-color:var(--danger);color:var(--danger)}
.sep{border-top:1px solid var(--border);margin:10px 0}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
@media(max-width:600px){.grid2,.grid3{grid-template-columns:1fr}}
.stat-box{background:var(--s2);border:1px solid var(--border);border-radius:5px;padding:10px 12px;text-align:center}
.stat-num{font-family:var(--serif);font-size:28px;margin-bottom:2px}
.stat-label{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em}
.fin-row{display:flex;align-items:center;gap:8px;padding:8px 10px;background:var(--s2);border:1px solid var(--border);border-radius:4px;margin-bottom:6px}
.fin-icon{font-size:16px;flex-shrink:0}.fin-body{flex:1}
.fin-label{font-size:10px;color:var(--text)}.fin-detail{font-size:9px;color:var(--dim);line-height:1.5}
.fin-state{font-size:9px;font-weight:700;letter-spacing:.08em;text-transform:uppercase}
.fin-state.tentative{color:var(--amber)}.fin-state.locked{color:var(--indigo)}.fin-state.final{color:var(--green)}.fin-state.slashed{color:var(--danger)}.fin-state.released{color:var(--cyan)}
*{scrollbar-width:thin;scrollbar-color:var(--s3) transparent}
/* address share box */
.addr-share{background:var(--s2);border:1px solid var(--indigo);border-radius:5px;padding:12px;word-break:break-all;font-size:9px;color:var(--indigo);line-height:1.8;cursor:pointer;transition:border-color .15s}
.addr-share:hover{border-color:var(--gold);color:var(--gold)}
</style>
</head>
<body>
<div id="app">

<div id="topbar">
  <span id="logo">Nexus <sub>wallet · v4</sub></span>
  <div class="hdot" id="hdot"></div>
  <div id="tb-right">
    <div class="bal-chip">
      <span class="amt" id="bal-top">0</span>
      <span class="sym" id="sym-top">ATT</span>
      <span class="lk" id="lk-top" style="display:none"></span>
    </div>
    <div class="sid-chip" id="sid-chip" onclick="copySid()">—</div>
  </div>
</div>

<div id="tabs">
  <div class="tab active" onclick="sw('balance')">Balance</div>
  <div class="tab" onclick="sw('sources')">Sources</div>
  <div class="tab" onclick="sw('send')">Send</div>
  <div class="tab" onclick="sw('lock')">Lock ⛓</div>
  <div class="tab" onclick="sw('resolve')">Resolve ⚖</div>
  <div class="tab" onclick="sw('settlement')">Settlement</div>
  <div class="tab" onclick="sw('genesis')">Genesis</div>
  <div class="tab" onclick="sw('receive')">Receive</div>
  <div class="tab" onclick="sw('proof')">⚔ Proof</div>
  <div class="tab" onclick="sw('log')">Log</div>
</div>

<div id="panels">

<!-- BALANCE -->
<div class="panel active" id="panel-balance">
  <div class="card">
    <div class="ct">Balance <span class="badge b-new">v4 · AUTH + CONSERVATION</span></div>
    <div class="bal-hero">
      <div class="amount" id="bal-display">0</div>
      <div class="sym" id="sym-display">ATT</div>
      <div class="lksub" id="lk-display" style="display:none"></div>
    </div>
    <div class="addr-box copyable" id="addr-box" onclick="copySid()">generating...</div>
    <div style="font-size:9px;color:var(--muted);margin-top:6px" id="utxo-summary"></div>
  </div>
  <div class="grid3">
    <div class="stat-box"><div class="stat-num gold" id="stat-unspent">0</div><div class="stat-label">Unspent Outputs</div></div>
    <div class="stat-box"><div class="stat-num" style="color:var(--indigo)" id="stat-locked">0</div><div class="stat-label">Locked Outputs</div></div>
    <div class="stat-box"><div class="stat-num" style="color:var(--danger)" id="stat-consumed">0</div><div class="stat-label">Consumed Sources</div></div>
  </div>
  <div class="card" id="incoming-card" style="display:none">
    <div class="ct">Pending Incoming <span id="inc-badge" class="badge b-ok"></span></div>
    <div id="incoming-list"></div>
  </div>
  <div class="card">
    <div class="ct">Paste &amp; Accept</div>
    <div class="field"><label>NX4 transition string</label><textarea id="paste-tx" placeholder="NX4:..."></textarea></div>
    <button class="btn btn-ghost" onclick="acceptPasted()">✓ Verify &amp; Accept</button>
    <div id="paste-result" style="font-size:10px;margin-top:6px;display:none;line-height:1.7"></div>
  </div>
</div>

<!-- SOURCES -->
<div class="panel" id="panel-sources">
  <div class="card">
    <div class="ct">All Outputs <span class="badge b-new">UTXO · AUTHORIZATION-BOUND</span></div>
    <div class="notice info" style="margin-bottom:10px">Each output is cryptographically bound to its owner's pubkey via the output ID hash. Only the holder of the matching private key can sign a valid spend of that output.</div>
    <div id="utxo-list"><div style="color:var(--muted);font-size:10px">No outputs yet.</div></div>
  </div>
  <div class="card">
    <div class="ct">Consumed Source Registry <span class="badge b-danger" id="consumed-badge">0</span></div>
    <div class="notice warn">Permanently consumed. Any transition referencing one of these sources is rejected before signature verification runs.</div>
    <div id="consumed-list" style="max-height:180px;overflow-y:auto"><div style="color:var(--muted);font-size:10px">Empty.</div></div>
  </div>
</div>

<!-- SEND -->
<div class="panel" id="panel-send">
  <div class="card">
    <div class="ct">Build Spend Transition <span class="badge b-new">OWNERSHIP-BOUND</span></div>
    <div class="notice warn" id="no-utxo-warn" style="display:none">No spendable outputs. Claim genesis first.</div>
    <div class="field"><label>Source Output</label><select id="src-sel"><option value="">— select —</option></select></div>
    <div class="field">
      <label>Recipient Address (NX4ADDR from Bob's Receive tab — Bob must be in a separate tab)</label>
      <input id="send-addr" placeholder="NX4ADDR:a1b2c3d4:base64x:base64y" oninput="parseRecipientAddr('send')">
      <div class="parsed-addr" id="send-addr-parsed"></div>
    </div>
    <div class="field"><label>Amount</label><input id="send-amt" type="number" value="100" min="0.001" step="0.001" oninput="updateSendPreview()"></div>
    <div class="field"><label>Memo</label><input id="send-memo" placeholder="payment memo"></div>
    <div class="tx-preview" id="send-preview" style="display:none">
      <div class="tx-line"><span class="lbl">CONSUMES</span><span class="val" id="sp-consumes">—</span></div>
      <div class="tx-line"><span class="lbl">OWNER CHECK</span><span class="val ok" id="sp-owner">✓ your key owns source</span></div>
      <div class="tx-line"><span class="lbl">SENDS</span><span class="val gold" id="sp-sends">—</span></div>
      <div class="tx-line"><span class="lbl">CHANGE</span><span class="val" id="sp-change">—</span></div>
      <div class="tx-line"><span class="lbl">CONSERVATION</span><span class="val" id="sp-conservation">—</span></div>
    </div>
    <button class="btn" onclick="buildSend()">→ Sign Spend Transition</button>
    <div class="tok-out" id="spend-out">
      <div class="ct" style="margin-bottom:6px">Signed Transition — share with recipient</div>
      <div class="tok-str" id="spend-str"></div>
      <div class="btn-row" style="margin-top:8px">
        <button class="btn btn-sm btn-ghost" onclick="copyStr('spend-str')">Copy</button>
        <button class="btn btn-sm btn-ghost" onclick="broadcastStr('spend-str')">Broadcast</button>
        <button class="btn btn-sm btn-ghost" onclick="document.getElementById('spend-out').classList.remove('show')">Clear</button>
      </div>
    </div>
  </div>
</div>

<!-- LOCK -->
<div class="panel" id="panel-lock">
  <div class="card">
    <div class="ct">Create Lock Output <span class="badge b-indigo">ENCUMBRANCE</span></div>
    <div class="notice info">A Lock consumes a spendable output and creates a LockOutput. The source is consumed immediately — funds cannot be moved while locked. Resolution requires the challenge window to have expired.</div>
    <div class="field"><label>Source Output to Lock</label><select id="lock-src-sel"><option value="">— select —</option></select></div>
    <div class="field"><label>Amount to Lock</label><input id="lock-amt" type="number" value="500" min="0.001" step="0.001" oninput="updateLockPreview()"></div>
    <div class="field">
      <label>Counterparty Address (NX4ADDR format)</label>
      <input id="lock-addr" placeholder="NX4ADDR:b2c3d4e5:base64x:base64y" oninput="parseRecipientAddr('lock')">
      <div class="parsed-addr" id="lock-addr-parsed"></div>
    </div>
    <div class="field"><label>Lock Terms (human-readable — will be hashed)</label><input id="lock-terms" placeholder="deliver-work-Q2-2026"></div>
    <div class="field"><label>Challenge Window (hours)</label><input id="lock-window" type="number" value="24" min="1" max="8760" oninput="updateLockPreview()"></div>
    <div class="tx-preview" id="lock-preview" style="display:none">
      <div class="tx-line"><span class="lbl">CONSUMES</span><span class="val" id="lp-consumes">—</span></div>
      <div class="tx-line"><span class="lbl">OWNER CHECK</span><span class="val ok">✓ your key owns source</span></div>
      <div class="tx-line"><span class="lbl">LOCKS</span><span class="val ind" id="lp-locks">—</span></div>
      <div class="tx-line"><span class="lbl">CHANGE</span><span class="val" id="lp-change">—</span></div>
