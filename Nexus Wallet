function resetAllData(){
  if(!confirm('This will delete ALL wallet data including keys, outputs, and the genesis authority. Continue?')) return;
  if(!confirm('Are you sure? This cannot be undone.')) return;
  // Clear per-SID state
  if(SID){
    localStorage.removeItem('nx4_outputs_'+SID);
    localStorage.removeItem('nx4_locks_'+SID);
    localStorage.removeItem('nx4_consumed_'+SID);
    localStorage.removeItem('nx4_journal_'+SID);
    localStorage.removeItem('nx4_sym_'+SID);
  }
  // Clear per-slot keypair
  localStorage.removeItem(KP_KEY);
  // Clear global genesis authority pin
  localStorage.removeItem('nx4_genesis_authority');
  // Clear outbox
  localStorage.removeItem(OUTBOX_KEY);
  // Clear session storage slot
  sessionStorage.removeItem('nx4_wallet_slot');
  log('ALL DATA CLEARED — reloading...','warn');
  setTimeout(()=>location.reload(), 500);
}

// ── PERSISTENCE ──
function persist(){
  if(!SID) return;
  try{
    localStorage.setItem('nx4_outputs_'+SID,  JSON.stringify([...OUTPUTS.entries()]));
    localStorage.setItem('nx4_locks_'+SID,    JSON.stringify([...LOCKS.entries()]));
    localStorage.setItem('nx4_consumed_'+SID, JSON.stringify([...CONSUMED]));
    localStorage.setItem('nx4_journal_'+SID,  JSON.stringify(JOURNAL.slice(-500)));
    localStorage.setItem('nx4_sym_'+SID, TOKEN_SYM);
    // FIX 2: Genesis authority is stored under a GLOBAL key — not per-SID.
    // The genesis authority is a property of the NETWORK, not of a single wallet identity.
    // Without this fix, opening a new tab creates a fresh SID with no authority pin,
    // allowing an attacker to present a forged genesis from a different authority.
    if(GENESIS_AUTHORITY_PUB) localStorage.setItem('nx4_genesis_authority', JSON.stringify(GENESIS_AUTHORITY_PUB));
  }catch(e){ log('Persist error: '+e.message,'warn'); }
}
function loadState(){
  try{
    const o=localStorage.getItem('nx4_outputs_'+SID); if(o) OUTPUTS=new Map(JSON.parse(o));
    const l=localStorage.getItem('nx4_locks_'+SID);   if(l) LOCKS=new Map(JSON.parse(l));
    const c=localStorage.getItem('nx4_consumed_'+SID);if(c) CONSUMED=new Set(JSON.parse(c));
    const j=localStorage.getItem('nx4_journal_'+SID); if(j) JOURNAL=JSON.parse(j);
    const s=localStorage.getItem('nx4_sym_'+SID);     if(s) TOKEN_SYM=s;
    // FIX 2: Read genesis authority from GLOBAL key — survives new tabs, new SIDs, new slots.
    // A fresh tab with a fresh identity still inherits the network's trusted genesis authority.
    const ga=localStorage.getItem('nx4_genesis_authority'); if(ga) GENESIS_AUTHORITY_PUB=JSON.parse(ga);
  }catch(e){ log('Load error: '+e.message,'warn'); }
}

// ── BOOT ──
async function boot(){
  log('NEXUS Wallet v4 · auto-transport booting...','info');
  log('Wallet slot: ' + WALLET_SLOT + ' (per-tab — open a new tab for a second wallet)','info');
  log('Fixes: ownership binding, AWARD pubkey, real challenge window, genesis authority sig, authorization, conservation','info');
  log('FIX 1: kernel death watchdog · FIX 2: global genesis pin · FIX 3: RESOLVE recursion · FIX 4: MessagePort IPC','info');
  const stored = localStorage.getItem(KP_KEY); // per-tab slot key
  if(stored){
    try{
      const {pub,priv}=JSON.parse(stored);
      KP={
        privateKey: await crypto.subtle.importKey('jwk',priv,{name:'ECDSA',namedCurve:'P-256'},true,['sign']),
        publicKey:  await crypto.subtle.importKey('jwk',{kty:pub.kty,crv:pub.crv,x:pub.x,y:pub.y},{name:'ECDSA',namedCurve:'P-256'},true,['verify']),
        _pub:pub,_priv:priv
      };
      SID=(await sha256(JSON.stringify(pub))).slice(0,8);
      loadState();
      log('Keypair restored · SID: '+SID,'ok');
    }catch(e){ await genKP(); }
  } else { await genKP(); }
  // FIX 2: Always load global genesis authority — even if genKP() created a fresh identity.
  // loadState() loads it when restoring an existing keypair. This covers the fresh-keypair path.
  // Without this, a fresh tab has GENESIS_AUTHORITY_PUB=null and accepts any authority.
  if(!GENESIS_AUTHORITY_PUB){
    try{
      const ga=localStorage.getItem('nx4_genesis_authority');
      if(ga) { GENESIS_AUTHORITY_PUB=JSON.parse(ga); log('Global genesis authority loaded','ok'); }
    }catch(e){}
  }
  if(GENESIS_OUTPUT && !CONSUMED.has(GENESIS_OUTPUT.id)){
    const r=await claimGenesisOutput(GENESIS_OUTPUT);
    if(r.ok) log('Embedded genesis claimed','ok');
  }
  renderAll();
  initKernelIPC();
  // Scan shared outbox for any transitions addressed to us
  // that were sent while this tab was closed or not yet open.
  setTimeout(scanInbox, 200);
}

async function genKP(){
  KP=await crypto.subtle.generateKey({name:'ECDSA',namedCurve:'P-256'},true,['sign','verify']);
  const pub=await crypto.subtle.exportKey('jwk',KP.publicKey);
  const priv=await crypto.subtle.exportKey('jwk',KP.privateKey);
  KP._pub=pub;KP._priv=priv;
  SID=(await sha256(JSON.stringify(pub))).slice(0,8);
  localStorage.setItem(KP_KEY, JSON.stringify({pub,priv})); // per-tab slot key
  log('New keypair · SID: '+SID,'ok');
}

